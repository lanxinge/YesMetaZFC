private inductive HostSequentBudgetAbort where
  | depthExhausted (depth maximum : Nat)
  | nodesExhausted (nodes maximum : Nat)
  | branchChildrenExhausted (current requested maximum : Nat)
deriving Repr

private def HostSequentBudgetAbort.message : HostSequentBudgetAbort → String
  | .depthExhausted depth maximum =>
      s!"focused sequent exhausted depth budget; depth={depth}; maxDepth={maximum}"
  | .nodesExhausted nodes maximum =>
      s!"focused sequent exhausted node budget; nodes={nodes}; maxNodes={maximum}"
  | .branchChildrenExhausted current requested maximum =>
      s!"focused sequent exhausted branch-child budget; current={current}; \
      requested={requested}; maxBranchChildren={maximum}"

private structure ApplyProbe where
  nodes : Nat := 0
  exhausted : Bool := false

private structure BranchBudgetCheckpoint where
  nodeCredits : Nat
  mainBranchDepth : Option Nat

private structure Runtime where
  config : Config
  prepared : HostNormalization.CheckedTransaction.Prepared
  analysis : HostPropAnalysis.Session
  stats : IO.Ref Stats
  chargedNodes : IO.Ref Nat
  nodeCredits : IO.Ref Nat
  mainBranchDepth : IO.Ref (Option Nat)
  chargedBranchChildren : IO.Ref Nat
  applyProbe : IO.Ref (Option ApplyProbe)
  budgetAbort : IO.Ref (Option HostSequentBudgetAbort)

private def Runtime.modify
    (runtime : Runtime) (update : Stats → Stats) : TacticM Unit :=
  runtime.stats.modify update

private def Runtime.abortBudget
    (runtime : Runtime) (abort : HostSequentBudgetAbort) : TacticM α := do
  runtime.budgetAbort.set (some abort)
  runtime.modify fun stats => {
    stats with budgetAborts := stats.budgetAborts + 1
  }
  throwError abort.message

private def Runtime.rethrowBudgetAbort
    (runtime : Runtime) : TacticM Unit := do
  if let some abort ← runtime.budgetAbort.get then
    throwError abort.message
  if let some probe ← runtime.applyProbe.get then
    if probe.exhausted then
      throwError
        "focused sequent exhausted the current speculative APPLY candidate"

private def Runtime.beginApplyProbe (runtime : Runtime) : TacticM Bool := do
  if (← runtime.applyProbe.get).isSome then
    return false
  runtime.applyProbe.set (some {})
  return true

private def Runtime.finishApplyProbe
    (runtime : Runtime) (ownsProbe : Bool) : TacticM Bool := do
  unless ownsProbe do
    return false
  let exhausted := (← runtime.applyProbe.get).any (·.exhausted)
  runtime.applyProbe.set none
  return exhausted

private def Runtime.branchBudgetCheckpoint
    (runtime : Runtime) : TacticM BranchBudgetCheckpoint := do
  return {
    nodeCredits := ← runtime.nodeCredits.get
    mainBranchDepth := ← runtime.mainBranchDepth.get
  }

private def Runtime.restoreBranchBudget
    (runtime : Runtime) (checkpoint : BranchBudgetCheckpoint) : TacticM Unit := do
  runtime.nodeCredits.set checkpoint.nodeCredits
  runtime.mainBranchDepth.set checkpoint.mainBranchDepth
  runtime.modify fun stats => {
    stats with
    activeNodeCredits := checkpoint.nodeCredits
    mainBranchDepth := checkpoint.mainBranchDepth
  }

/--
登记主命题主干第一次产生的粗粒度分支前沿。

只有该前沿的直接子目标可以奖励节点信用；分支内部继续产生的 SPLIT、CASES 或
CONSTRUCTOR 不参与奖励。单子目标变换不建立前沿，speculative APPLY 也不能建立。
-/
private def Runtime.claimMainBranchFrontier
    (runtime : Runtime) (depth childCount : Nat) : TacticM Bool := do
  if childCount <= 1 || (← runtime.applyProbe.get).isSome then
    return false
  match ← runtime.mainBranchDepth.get with
  | some mainDepth =>
      return mainDepth == depth
  | none =>
      runtime.mainBranchDepth.set (some depth)
      runtime.modify fun stats => {
        stats with mainBranchDepth := some depth
      }
      return true

/--
主分支前沿的一个直接子目标完整闭合后增加有上限的节点信用。

外层候选随后回溯时，active credit 与前沿身份一起恢复到候选开始前的值。
-/
private def Runtime.rewardClosedMainBranch
    (runtime : Runtime) (isMainBranch : Bool) : TacticM Unit := do
  if !isMainBranch || runtime.config.mainBranchNodeCredit == 0 ||
      runtime.config.maxEarnedNodeCredits == 0 then
    return
  let current ← runtime.nodeCredits.get
  let next :=
    Nat.min runtime.config.maxEarnedNodeCredits
      (current + runtime.config.mainBranchNodeCredit)
  if next > current then
    runtime.nodeCredits.set next
    runtime.modify fun stats => {
      stats with
      mainBranchCreditEvents := stats.mainBranchCreditEvents + 1
      nodeCreditsGranted := stats.nodeCreditsGranted + (next - current)
      activeNodeCredits := next
    }

private def Runtime.visit
    (runtime : Runtime) (depth : Nat) : TacticM Unit := do
  if depth > runtime.config.maxDepth then
    runtime.abortBudget <|
      .depthExhausted depth runtime.config.maxDepth
  match ← runtime.applyProbe.get with
  | some probe =>
      if probe.nodes >= runtime.config.maxApplyProbeNodes then
        runtime.applyProbe.set (some { probe with exhausted := true })
        runtime.modify fun stats => {
          stats with applyProbeAborts := stats.applyProbeAborts + 1
        }
        throwError
          "focused sequent exhausted speculative APPLY nodes; \
          nodes={probe.nodes}; maxApplyProbeNodes={runtime.config.maxApplyProbeNodes}"
      runtime.applyProbe.set (some { probe with nodes := probe.nodes + 1 })
      runtime.modify fun stats => {
        stats with
        nodes := stats.nodes + 1
        applyProbeNodes := stats.applyProbeNodes + 1
        maxDepth := Nat.max stats.maxDepth depth
      }
  | none =>
      let chargedNodes ← runtime.chargedNodes.get
      let nodeCredits ← runtime.nodeCredits.get
      let nodeAllowance := runtime.config.maxNodes + nodeCredits
      if chargedNodes >= nodeAllowance then
        runtime.abortBudget <|
          .nodesExhausted chargedNodes nodeAllowance
      runtime.chargedNodes.set (chargedNodes + 1)
      runtime.modify fun stats => {
        stats with
        nodes := stats.nodes + 1
        chargedNodes := stats.chargedNodes + 1
        maxDepth := Nat.max stats.maxDepth depth
      }

private def Runtime.addBranchChildren
    (runtime : Runtime) (count : Nat) : TacticM Unit := do
  if (← runtime.applyProbe.get).isSome then
    runtime.modify fun stats => {
      stats with branchChildren := stats.branchChildren + count
    }
  else
    let chargedChildren ← runtime.chargedBranchChildren.get
    if chargedChildren + count > runtime.config.maxBranchChildren then
      runtime.abortBudget <|
        .branchChildrenExhausted chargedChildren count
          runtime.config.maxBranchChildren
    runtime.chargedBranchChildren.set (chargedChildren + count)
    runtime.modify fun stats => {
      stats with
      branchChildren := stats.branchChildren + count
      chargedBranchChildren := stats.chargedBranchChildren + count
    }

private def pushNameUnique (names : Array Name) (name : Name) : Array Name :=
  if names.contains name then names else names.push name

private def normalizationUsedDeclarations
    (journal : HostNormalization.CheckedTransaction.Journal) :
    Array Name :=
  let fromHypotheses :=
    journal.hypotheses.foldl
      (fun declarations hypothesis =>
        hypothesis.closure.usedDeclarations.foldl
          pushNameUnique declarations) #[]
  match journal.target? with
  | none =>
      fromHypotheses
  | some target =>
      target.usedDeclarations.foldl pushNameUnique fromHypotheses

private def normalizationPathCount
    (journal : HostNormalization.CheckedTransaction.Journal) : Nat :=
  let hypothesisPaths :=
    journal.hypotheses.foldl
      (fun total hypothesis => total + hypothesis.closure.path) 0
  hypothesisPaths + (journal.target?.map (·.path) |>.getD 0)

private def normalizationCheckerPasses
    (journal : HostNormalization.CheckedTransaction.Journal) : Nat :=
  let hypothesisPasses :=
    journal.hypotheses.foldl
      (fun total hypothesis =>
        total + if hypothesis.closure.checkerPassed then 1 else 0) 0
  hypothesisPasses +
    (journal.target?.map
      (fun target => if target.checkerPassed then 1 else 0) |>.getD 0)

private def normalizationReplayedSteps
    (journal : HostNormalization.CheckedTransaction.Journal) : Nat :=
  let hypothesisSteps :=
    journal.hypotheses.foldl
      (fun total hypothesis =>
        total + hypothesis.closure.replayedSteps) 0
  hypothesisSteps +
    (journal.target?.map (·.replayedSteps) |>.getD 0)

private def Runtime.recordNormalizationPrepare
    (runtime : Runtime)
    (prepare : HostNormalization.CheckedTransaction.PrepareStats) :
    TacticM Unit :=
  runtime.modify fun stats => {
    stats with
    normalizationPrepareCompileNs := prepare.compileElapsedNs
    normalizationPrepareElapsedNs := prepare.prepareElapsedNs
    normalizationPrepareValidationNs := prepare.validationElapsedNs
    normalizationRules := prepare.rules
    normalizationIndexedRules := prepare.indexedRules
    normalizationFallbackRules := prepare.fallbackRules
  }

private def Runtime.recordNormalization
    (runtime : Runtime)
    (journal : HostNormalization.CheckedTransaction.Journal)
    (changed discharged : Bool) : TacticM Unit :=
  let targetChanged :=
    journal.target?.any fun target => target.path > 0
  let usedDeclarations := normalizationUsedDeclarations journal
  runtime.modify fun stats => {
    stats with
    normalizationCalls := stats.normalizationCalls + 1
    normalizationChanges :=
      stats.normalizationChanges + if changed then 1 else 0
    normalizationCheckedClosures :=
      stats.normalizationCheckedClosures + journal.checkedClosures
    normalizationResultValidatedClosures :=
      stats.normalizationResultValidatedClosures +
        journal.resultValidatedClosures
    normalizationNoOpClosures :=
      stats.normalizationNoOpClosures + journal.noOpClosures
    normalizationNoOpReplayPrunes :=
      stats.normalizationNoOpReplayPrunes + journal.noOpReplayPrunes
    normalizationReplayedClosures :=
      stats.normalizationReplayedClosures + journal.replayedClosures
    normalizationNodes := stats.normalizationNodes + journal.nodes
    normalizationAttempts := stats.normalizationAttempts + journal.attempts
    normalizationConservativeAttempts :=
      stats.normalizationConservativeAttempts + journal.conservativeAttempts
    normalizationConservativeEdges :=
      stats.normalizationConservativeEdges + journal.conservativeEdges
    normalizationPhaseQueries :=
      stats.normalizationPhaseQueries + journal.phaseQueries
    normalizationEmptyPhasePrunes :=
      stats.normalizationEmptyPhasePrunes + journal.emptyPhasePrunes
    normalizationBacktracks :=
      stats.normalizationBacktracks + journal.backtracks
    normalizationCycles :=
      stats.normalizationCycles + journal.cycles
    normalizationPaths :=
      stats.normalizationPaths + normalizationPathCount journal
    normalizationCandidateRules :=
      stats.normalizationCandidateRules + journal.candidateRules
    normalizationIndexQueries :=
      stats.normalizationIndexQueries + journal.indexQueries
    normalizationIndexedCandidates :=
      stats.normalizationIndexedCandidates + journal.indexedCandidates
    normalizationRewrites :=
      stats.normalizationRewrites + journal.rewrites
    normalizationTargetChanges :=
      stats.normalizationTargetChanges + if targetChanged then 1 else 0
    normalizationHypothesisCandidates :=
      stats.normalizationHypothesisCandidates +
        journal.hypothesisCandidates
    normalizationHypothesesSkipped :=
      stats.normalizationHypothesesSkipped + journal.hypothesesSkipped
    normalizationHypothesesChanged :=
      stats.normalizationHypothesesChanged + journal.hypothesesChanged
    normalizationHypothesesCleared :=
      stats.normalizationHypothesesCleared + journal.hypothesesCleared
    normalizationResourcesRemapped :=
      stats.normalizationResourcesRemapped + journal.resourcesRemapped
    normalizationDischarged :=
      stats.normalizationDischarged + if discharged then 1 else 0
    normalizationCheckerPasses :=
      stats.normalizationCheckerPasses +
        normalizationCheckerPasses journal
    normalizationReplayedSteps :=
      stats.normalizationReplayedSteps +
        normalizationReplayedSteps journal
    normalizationProviderCalls :=
      stats.normalizationProviderCalls + journal.providerCalls
    normalizationClosureElapsedNs :=
      stats.normalizationClosureElapsedNs + journal.closureElapsedNs
    normalizationResultValidationNs :=
      stats.normalizationResultValidationNs +
        journal.resultValidationNs
    normalizationPayloadElapsedNs :=
      stats.normalizationPayloadElapsedNs + journal.payloadElapsedNs
    normalizationCheckerElapsedNs :=
      stats.normalizationCheckerElapsedNs + journal.checkerElapsedNs
    normalizationSnapshotElapsedNs :=
      stats.normalizationSnapshotElapsedNs + journal.snapshotElapsedNs
    normalizationProofReplayElapsedNs :=
      stats.normalizationProofReplayElapsedNs +
        journal.proofReplayElapsedNs
    normalizationArtifactValidationNs :=
      stats.normalizationArtifactValidationNs +
        journal.artifactValidationNs
    normalizationApplicationElapsedNs :=
      stats.normalizationApplicationElapsedNs +
        journal.applicationElapsedNs
    normalizationElapsedNs :=
      stats.normalizationElapsedNs + journal.elapsedNs
    normalizationRollbacks :=
      stats.normalizationRollbacks + journal.rollbacks
    normalizationUsedDeclarations :=
      usedDeclarations.foldl
        pushNameUnique stats.normalizationUsedDeclarations
  }

private def Runtime.recordTerminal
    (runtime : Runtime) (terminal : HostTerminalStats)
    (closed : Bool) : TacticM Unit :=
  runtime.modify fun stats => {
    stats with
    terminalCalls := stats.terminalCalls + 1
    terminalClosures :=
      stats.terminalClosures + if closed then 1 else 0
    terminalFailures :=
      stats.terminalFailures + if closed then 0 else 1
    providerCalls := stats.providerCalls + terminal.providerCalls
    providerBuilds := stats.providerBuilds + terminal.providerBuilds
    providerSkips := stats.providerSkips + terminal.providerSkips
    contextPreparations :=
      stats.contextPreparations + terminal.contextPreparations
    summaryEvaluations :=
      stats.summaryEvaluations + terminal.summaryEvaluations
  }

