/-- 读取 tactic options 后运行聚焦相继式原型。 -/
unsafe def runDefault : TacticM Stats := do
  run (← defaultConfig)

@[tactic ProveAutoRequest.proveAutoRouted]
unsafe def evalProveAutoRouted : Tactic :=
  fun _ => do
    withProveAutoResources do
      discard runDefault

end HostFocusedSequent
