/-- 当前局部上下文中稳定、显式、无 metavariable 的 Prop proof 槽位。 -/
private def localProofResources : MetaM (Array FVarId) := do
  let mut resources := #[]
  for declaration in (← getLCtx) do
    if declaration.isLet || declaration.isImplementationDetail ||
        declaration.isAuxDecl || declaration.binderInfo.isInstImplicit then
      continue
    let proposition ← instantiateMVars declaration.type
    if proposition.hasMVar || !(← isProp proposition) then
      continue
    resources := resources.push declaration.fvarId
  return resources

/-- 聚焦右规则区分对象 `Forall` 与非依赖 Prop 蕴含。 -/
private inductive IntroKind where
  | implication
  | objectBinder (name : Name)

private def introKind? (target : Expr) : MetaM (Option IntroKind) := do
  let target ← whnf target
  let .forallE binderName domain body _ := target
    | return none
  if ← isProp domain then
    if body.hasLooseBVars then
      return none
    return some .implication
  let baseName := if binderName.isAnonymous then `fixed else binderName
  return some (.objectBinder baseName)

private def hostExpressionsDefEq
    (left right : Expr) : MetaM Bool := do
  let savedState ← saveState
  let result ← isDefEqGuarded left right
  savedState.restore
  return result

private def isRewriteProposition (proposition : Expr) : MetaM Bool := do
  let savedState ← saveState
  let eligible ←
    try
      let proposition ← instantiateMVars proposition
      let (arguments, binderInfos, conclusion) ←
        forallMetaTelescopeReducing proposition
      let mut supported := true
      for index in [0 : arguments.size] do
        let binderInfo := binderInfos[index]!
        let domain ← instantiateMVars (← inferType arguments[index]!)
        if binderInfo.isInstImplicit || !binderInfo.isExplicit ||
            (← isProp domain) then
          supported := false
      let conclusion ← whnf (← instantiateMVars conclusion)
      pure <| supported &&
        (conclusion.isAppOfArity ``Eq 3 ||
          conclusion.isAppOfArity ``Iff 2)
    catch _ =>
      pure false
  savedState.restore
  return eligible

/--
用一个局部等式或等价 proof 改写目标；显式对象 binder 由目标匹配实例化。

只接受没有附加 side goal 且确实改变目标表达式的结果；调用者负责事务回滚。
-/
private def rewriteTarget?
    (goal : MVarId) (ruleProof : Expr) (reverse : Bool) :
    MetaM (Option MVarId) := goal.withContext do
  let target ← instantiateMVars (← goal.getType)
  let result ← goal.rewrite target ruleProof (symm := reverse)
  unless result.mvarIds.isEmpty do
    return none
  if Expr.equal result.eNew target then
    return none
  let child ← goal.replaceTargetEq result.eNew result.eqProof
  return some child

/--
用量化等式或等价规则改写一个局部 proof 的命题，并构造经 `Eq.mp` 检查的新 proof。

探针只返回无 side goal、无 metavariable 且确实改变命题的结果；调用者负责候选去重。
-/
private def forwardRewriteProof?
    (goal : MVarId) (ruleProof : Expr) (support : FVarId) (reverse : Bool) :
    MetaM (Option (Expr × Expr)) := goal.withContext do
  let savedState ← saveState
  let result? ←
    try
      let proposition ← instantiateMVars (← support.getType)
      let result ← goal.rewrite proposition ruleProof (symm := reverse)
      if !result.mvarIds.isEmpty || Expr.equal result.eNew proposition then
        pure none
      else
        let rewritten ← instantiateMVars result.eNew
        let equality ← instantiateMVars result.eqProof
        if !(← getMVarsNoDelayed rewritten).isEmpty ||
            !(← getMVarsNoDelayed equality).isEmpty then
          pure none
        else
          let proof ←
            instantiateMVars (← mkAppM ``Eq.mp #[equality, mkFVar support])
          if !(← getMVarsNoDelayed proof).isEmpty ||
              !(← isDefEq (← inferType proof) rewritten) then
            pure none
          else
            pure (some (rewritten, proof))
    catch _ =>
      pure none
  savedState.restore
  return result?

/--
当 rewrite 规则的一侧是存在命题时，用 support 中实际出现的局部对象作唯一一层包装。

生成的 `Exists.intro` 与后续 Iff/Eq rewrite 都保留普通 Lean proof；失败尝试完整回滚。
-/
private def forwardExistentialRewriteProof?
    (goal : MVarId) (ruleProof : Expr) (support : FVarId) (reverse : Bool) :
    MetaM (Option (Expr × Expr)) := goal.withContext do
  let savedState ← saveState
  let proposition ← instantiateMVars (← support.getType)
  let witnessCandidates := (Lean.collectFVars {} proposition).fvarIds
  let mut result? : Option (Expr × Expr) := none
  for witnessId in witnessCandidates do
    let attemptState ← saveState
    try
      let domain ← instantiateMVars (← witnessId.getType)
      if domain.hasMVar || (← isProp domain) then
        attemptState.restore
        continue
      let witness := mkFVar witnessId
      let predicate ← mkLambdaFVars #[witness] proposition
      let level := (← inferType domain).sortLevel!
      let existential :=
        mkApp2 (mkConst ``Exists [level]) domain predicate
      let existentialProof :=
        mkApp4 (mkConst ``Exists.intro [level])
          domain predicate witness (mkFVar support)
      let rewriteResult ←
        goal.rewrite existential ruleProof (symm := reverse)
      if !rewriteResult.mvarIds.isEmpty ||
          Expr.equal rewriteResult.eNew existential then
        attemptState.restore
        continue
      let rewritten ← instantiateMVars rewriteResult.eNew
      let equality ← instantiateMVars rewriteResult.eqProof
      if !(← getMVarsNoDelayed rewritten).isEmpty ||
          !(← getMVarsNoDelayed equality).isEmpty then
        attemptState.restore
        continue
      let proof ← instantiateMVars <|
        ← mkAppM ``Eq.mp #[equality, existentialProof]
      if !(← getMVarsNoDelayed proof).isEmpty ||
          !(← isDefEq (← inferType proof) rewritten) then
        attemptState.restore
        continue
      result? := some (rewritten, proof)
      break
    catch _ =>
      attemptState.restore
  let finalResult ←
    match result? with
    | some (rewritten, proof) =>
        pure <| some
          (← instantiateMVars rewritten, ← instantiateMVars proof)
    | none =>
        pure none
  savedState.restore
  return finalResult

private structure ForwardRewriteResource where
  resource : FVarId
  proposition : Expr
  label : Name
  generationRank : Nat
  targetOverlap : Nat
  relevance : Nat
  weight : Nat
  age : Nat

private structure HostRewriteRule where
  proof : Expr
  proposition : Expr
  label : Name
  sourceLabel : Name
  projectionPath : Array Name := #[]
  score : Nat := 0

private def expressionFVarOverlap (left right : Expr) : Nat :=
  let leftFVars := (Lean.collectFVars {} left).fvarIds
  let rightFVars := (Lean.collectFVars {} right).fvarIds
  leftFVars.foldl
    (fun count fvar => if rightFVars.contains fvar then count + 1 else count)
    0

/-- 命题在当前路径生成序列中的最新位置；零表示它不是生成资源。 -/
private def generatedPropositionRank
    (generated : Array Expr) (proposition : Expr) : Nat :=
  (generated.mapIdx fun index generatedProposition =>
      if Expr.equal generatedProposition proposition then index + 1 else 0)
    |>.foldl Nat.max 0

/--
Vampire 式 selected-resource 排序视图。

由当前产生式直接暴露的新资源优先；随后比较目标对象重叠、语义相关性、表达式深度
和稳定年龄。该数组只保存当前叶的 FVar 与 proof-free 排序元数据，不跨分支缓存。
-/
private def orderForwardRewriteResources
    (target : Expr) (resources : Array FVarId)
    (generated : Array Expr) :
    MetaM (Array ForwardRewriteResource) := do
  let targetProfile ← ContextRelevance.collect target
  let mut ordered := #[]
  for age in [0 : resources.size] do
    let resource := resources[age]!
    let proposition ← instantiateMVars (← resource.getType)
    let profile ← ContextRelevance.collect proposition
    ordered := ordered.push {
      resource := resource
      proposition := proposition
      label := (← resource.getDecl).userName
      generationRank := generatedPropositionRank generated proposition
      targetOverlap := expressionFVarOverlap target proposition
      relevance := ContextRelevance.score targetProfile profile
      weight := proposition.approxDepth.toNat
      age := age
    }
  return ordered.qsort fun left right =>
    if left.generationRank == right.generationRank then
      if left.targetOverlap == right.targetOverlap then
        if left.relevance == right.relevance then
          if left.weight == right.weight then
            left.age < right.age
          else
            left.weight < right.weight
        else
          left.relevance > right.relevance
      else
        left.targetOverlap > right.targetOverlap
    else
      left.generationRank > right.generationRank

/-!
规范 fingerprint 只服务当前相继式递归的环检测。它保存 alpha-stable 的局部类型、
非命题 let 值、目标与 proof-resource 槽位，不保存 proof、metavariable 或 SavedState。
-/
private structure HostSequentFingerprint where
  metadata : Array Nat
  expressions : Array Expr

/--
当前 DFS 分支的稳定历史。

`fingerprints` 防止完整相继式状态回环；`generated` 保留已产生事实，即使该事实随后被
`CASES` 消费并从局部资源中移除，也不能在同一分支上再次生成。
-/
private structure HostSequentSearchPath where
  fingerprints : Array HostSequentFingerprint := #[]
  generated : Array Expr := #[]
  forwardSimplified : Array Expr := #[]
  preferredWitnesses : Array Expr := #[]
  preferredCases : Array Expr := #[]
  preferGeneratedRewrite : Bool := false
  rewriteStreak : Nat := 0
  deriving Inhabited

private def hostSequentBinderInfoCode : BinderInfo → Nat
  | .default => 0
  | .implicit => 1
  | .strictImplicit => 2
  | .instImplicit => 3

private def hostSequentLocalKindCode : LocalDeclKind → Nat
  | .default => 0
  | .implDetail => 1
  | .auxDecl => 2

private def hostSequentExprArraysEqual
    (left right : Array Expr) : Bool := Id.run do
  if left.size != right.size then
    return false
  for index in [0 : left.size] do
    unless Expr.equal left[index]! right[index]! do
      return false
  return true

private def HostSequentFingerprint.same
    (left right : HostSequentFingerprint) : Bool :=
  left.metadata == right.metadata &&
    hostSequentExprArraysEqual left.expressions right.expressions

private def makeHostSequentFingerprint?
    (target : Expr) (resources : Array FVarId) :
    MetaM (Option HostSequentFingerprint) := do
  let mut localDecls : Array LocalDecl := #[]
  let mut localFVars : Array Expr := #[]
  let mut canonicalFVars : Array Expr := #[]
  for localDecl in (← getLCtx) do
    let index := localDecls.size
    localDecls := localDecls.push localDecl
    localFVars := localFVars.push (mkFVar localDecl.fvarId)
    canonicalFVars := canonicalFVars.push <|
      mkFVar { name := Name.num `_proveAutoSequentFingerprint index }
  let canonicalize (expression : Expr) :=
    expression.replaceFVars localFVars canonicalFVars
  let mut metadata := #[localDecls.size]
  let mut expressions := #[]
  for localDecl in localDecls do
    let type ← instantiateMVars localDecl.type
    if type.hasMVar then
      return none
    let typeIsProp ← isProp type
    let value? :=
      if localDecl.isLet && !typeIsProp then
        localDecl.value?
      else
        none
    metadata := metadata.push (hostSequentBinderInfoCode localDecl.binderInfo)
    metadata := metadata.push (hostSequentLocalKindCode localDecl.kind)
    metadata := metadata.push (if localDecl.isLet then 1 else 0)
    metadata := metadata.push (if value?.isSome then 1 else 0)
    expressions := expressions.push (canonicalize type)
    if let some value := value? then
      let value ← instantiateMVars value
      if value.hasMVar then
        return none
      expressions := expressions.push (canonicalize value)
  let target ← whnf (← instantiateMVars target)
  if target.hasMVar then
    return none
  expressions := expressions.push (canonicalize target)
  metadata := metadata.push resources.size
  for resource in resources do
    let mut slot? : Option Nat := none
    for index in [0 : localDecls.size] do
      if localDecls[index]!.fvarId == resource then
        slot? := some index
        break
    let some slot := slot?
      | return none
    metadata := metadata.push slot
    let proposition ← instantiateMVars localDecls[slot]!.type
    if proposition.hasMVar then
      return none
    expressions := expressions.push (canonicalize proposition)
  return some {
    metadata := metadata
    expressions := expressions
  }

private def fingerprintOnPath
    (path : Array HostSequentFingerprint)
    (fingerprint : HostSequentFingerprint) : Bool :=
  path.any fun previous => previous.same fingerprint

private def generationOnPath
    (path : HostSequentSearchPath) (proposition : Expr) : Bool :=
  path.generated.any fun generated => Expr.equal generated proposition

private def rememberGeneration
    (path : HostSequentSearchPath) (proposition : Expr) :
    HostSequentSearchPath :=
  { path with generated := path.generated.push proposition }

/-- 记录已由一条 proof-producing rewrite 简化过的具体 support。 -/
private def rememberForwardSimplification
    (path : HostSequentSearchPath) (proposition : Expr) :
    HostSequentSearchPath :=
  if path.forwardSimplified.any fun existing =>
      Expr.equal existing proposition then
    path
  else
    { path with
      forwardSimplified := path.forwardSimplified.push proposition }

/-- 对象替换后同步迁移路径中的生成命题与偏好见证。 -/
private def remapSearchPath
    (path : HostSequentSearchPath) (substitution : FVarSubst) :
    HostSequentSearchPath := {
  path with
  generated := path.generated.map substitution.apply
  forwardSimplified := path.forwardSimplified.map substitution.apply
  preferredWitnesses := path.preferredWitnesses.map substitution.apply
  preferredCases := path.preferredCases.map substitution.apply
}

private def rememberRewrite
    (path : HostSequentSearchPath) : HostSequentSearchPath :=
  { path with rewriteStreak := path.rewriteStreak + 1 }

private def resetRewriteStreak
    (path : HostSequentSearchPath) : HostSequentSearchPath :=
  { path with rewriteStreak := 0 }

private def analysisRewriteRules
    (runtime : Runtime) (view : HostPropAnalysis.View)
    (path : HostSequentSearchPath) :
    MetaM (Array HostRewriteRule) := do
  let mut rules := #[]
  for ranked in view.equalities do
    let some resource ← runtime.analysis.resource? ranked.resource
      | continue
    if generationOnPath path resource.proposition then
      continue
    unless ← isRewriteProposition resource.proposition do
      continue
    rules := rules.push {
      proof := resource.proof
      proposition := resource.proposition
      label := resource.label
      sourceLabel := resource.sourceLabel
      projectionPath := resource.projectionPath
      score := ranked.score
    }
  return rules

private def tryProjectedInitialRule
    (runtime : Runtime) (goal : MVarId)
    (view : HostPropAnalysis.View) :
    MetaM (Option HostPropAnalysis.Resource) := goal.withContext do
  let target ← instantiateMVars (← goal.getType)
  if target.hasMVar then
    return none
  for resourceId in view.exact do
    let some resource ← runtime.analysis.resource? resourceId
      | continue
    let proposition ← instantiateMVars resource.proposition
    let proofType ← instantiateMVars (← inferType resource.proof)
    if proposition.hasMVar || proofType.hasMVar ||
        !(← isProp proposition) then
      continue
    unless ← hostExpressionsDefEq proofType proposition do
      continue
    unless ← hostExpressionsDefEq proposition target do
      continue
    let savedState ← saveState
    try
      goal.assign resource.proof
      return some resource
    catch _ =>
      savedState.restore
  return none

private def tryFalseInitialRule
    (goal : MVarId) :
    MetaM (Option Name) := goal.withContext do
  for declaration in (← getLCtx) do
    if declaration.binderInfo.isInstImplicit then
      continue
    let proposition ← whnf (← instantiateMVars declaration.type)
    unless proposition.isConstOf ``False do
      continue
    let savedState ← saveState
    try
      let target ← instantiateMVars (← goal.getType)
      let resultLevel := (← inferType target).sortLevel!
      let proof :=
        mkApp2 (mkConst ``False.elim [resultLevel]) target declaration.toExpr
      goal.assign proof
      return some declaration.userName
    catch _ =>
      savedState.restore
  return none

/--
检查一个 proof 的正向结构投影中是否已经携带当前目标。

这里只沿结构字段递归，不进入蕴含、全称或新的存在量词，因此可用于判断一次
`CHOOSE` 是否会立即暴露可闭合字段。
-/
private partial def proofProjectsTargetAux
    (proof target : Expr) (seen : PHashMap Expr Bool) :
    MetaM Bool := do
  let proposition ← instantiateMVars (← inferType proof)
  if proposition.hasMVar then
    return false
  if ← hostExpressionsDefEq proposition target then
    return true
  if seen.contains proposition then
    return false
  let seen := seen.insert proposition true
  let reduced ← whnf proposition
  let some structureName := reduced.getAppFn.constName?
    | return false
  let some structureInfo := getStructureInfo? (← getEnv) structureName
    | return false
  for fieldName in structureInfo.fieldNames do
    let projection ← mkProjection proof fieldName
    let projectionType ← instantiateMVars (← inferType projection)
    if projectionType.hasMVar || !(← isProp projectionType) then
      continue
    if ← proofProjectsTargetAux projection target seen then
      return true
  return false

private def proofProjectsTarget
    (proof target : Expr) : MetaM Bool :=
  proofProjectsTargetAux proof target {}

private def renderResourceLabel (resource : FVarId) : MetaM Name := do
  return (← resource.getDecl).userName

private structure ApplyCandidate where
  label : Name
  proof : Expr
  rank : Nat := 100
deriving Inhabited

private structure ScoredApplyCandidate where
  candidate : ApplyCandidate
  admitted : Bool := false
  exactPremises : Nat := 0
  remainingPremises : Nat := 0
  age : Nat := 0

private def assignAnalysisPremise?
    (runtime : Runtime) (view : HostPropAnalysis.View)
    (argument : MVarId) (premise : Expr) :
    MetaM Bool := do
  for resourceId in view.resources do
    let some resource ← runtime.analysis.resource? resourceId
      | continue
    let resourceState ← saveState
    let proofType ← instantiateMVars (← inferType resource.proof)
    if !proofType.hasMVar && (← isDefEq premise proofType) then
      argument.assign resource.proof
      return true
    resourceState.restore
  return false

/--
只把表面已经暴露逻辑结构的唯一残余前提交给递归相继式。

命名语义谓词即使可约成 `∀` 或 `↔`，也必须先由上下文中的真实 proof 确定其实例；
否则 target-headed APPLY 会把尚未暴露的结构事实变成新的开放搜索目标。
-/
private def visibleHostSequentResidualPremise (premise : Expr) : Bool :=
  let premise := premise.consumeMData
  premise.isForall ||
    premise.isAppOfArity ``And 2 ||
    premise.isAppOfArity ``Or 2 ||
    premise.isAppOfArity ``Iff 2 ||
    premise.isAppOfArity ``Exists 2 ||
    premise.isAppOfArity ``Not 1 ||
    premise.isConstOf ``True

/--
用当前 analysis frame 中已经存在的显式命题前提特化声明规则。

目标先确定结论参数，随后按声明顺序消费真实局部 proof。全覆盖时直接闭合；否则只
允许留下一个显式命题前提，并且此前至少消费过一个真实 proof。这样外延类规则仍可
把唯一逐点条件交给相继式分解，而完全没有实例证据的单前提规则不会制造新子目标。
-/
private def specializeRegisteredApplyCandidate?
    (runtime : Runtime) (view : HostPropAnalysis.View)
    (target : Expr) (candidate : ApplyCandidate) :
    MetaM (Option ApplyCandidate) := do
  let savedState ← saveState
  let result? ←
    try
      let proposition ← instantiateMVars (← inferType candidate.proof)
      let (arguments, binderInfos, conclusion) ←
        forallMetaTelescope proposition
      unless ← isDefEqGuarded conclusion target do
        throwError "registered APPLY conclusion does not match"
      let mut appliedArguments := #[]
      let mut seededPremises : Nat := 0
      let mut firstMissing? : Option Nat := none
      for index in [0 : arguments.size] do
        let argument := arguments[index]!
        if ← argument.mvarId!.isAssigned then
          appliedArguments := appliedArguments.push argument
          continue
        let domain ← instantiateMVars (← inferType argument)
        if binderInfos[index]!.isExplicit && (← isProp domain) then
          if ←
              assignAnalysisPremise?
                runtime view argument.mvarId! domain then
            seededPremises := seededPremises + 1
            appliedArguments := appliedArguments.push argument
          else
            firstMissing? := some index
            break
        else
          appliedArguments := appliedArguments.push argument
      let instantiatedArguments ← appliedArguments.mapM instantiateMVars
      if instantiatedArguments.any fun argument => argument.hasMVar then
        throwError "registered APPLY applied prefix contains metavariables"
      else if let some firstMissing := firstMissing? then
        let mut residualPremises : Nat := 0
        for index in [firstMissing : arguments.size] do
          let domain ← instantiateMVars (← inferType arguments[index]!)
          if binderInfos[index]!.isExplicit && (← isProp domain) then
            residualPremises := residualPremises + 1
        if seededPremises == 0 || residualPremises != 1 then
          throwError
            "registered APPLY residual filter rejected seeded={seededPremises}, \
            residual={residualPremises}"
        else
          let residualPremise ←
            instantiateMVars (← inferType arguments[firstMissing]!)
          unless visibleHostSequentResidualPremise residualPremise do
            throwError
              "registered APPLY residual premise has no visible logical structure"
          let proof ←
            instantiateMVars (mkAppN candidate.proof instantiatedArguments)
          if !(← getMVarsNoDelayed proof).isEmpty then
            throwError "registered APPLY partial proof contains metavariables"
          else
            pure (some { candidate with proof := proof })
      else
        let proof ←
          instantiateMVars (mkAppN candidate.proof instantiatedArguments)
        if !(← getMVarsNoDelayed proof).isEmpty then
          throwError "registered APPLY closing proof contains metavariables"
        else
          let proofType ← instantiateMVars (← inferType proof)
          unless ← isDefEqGuarded proofType target do
            throwError "registered APPLY proof no longer closes the target"
          pure (some { candidate with proof := proof })
    catch error =>
      trace[YesMetaZFC.proveAuto.sequent]
        "registered.apply.filtered resource={candidate.label}; \
        target={target}; reason={error.toMessageData}"
      pure none
  let result? ← result?.mapM fun specialized => do
    return { specialized with proof := ← instantiateMVars specialized.proof }
  savedState.restore
  return result?

private structure OverlapCutCandidate where
  apply : ApplyCandidate
  cut : Expr
  left : Expr
  right : Expr

private inductive ApplyPass where
  | surface
  | probe
  | fallback
deriving BEq, Repr

private def ApplyPass.label : ApplyPass → String
  | .surface => "surface"
  | .probe => "probe"
  | .fallback => "fallback"

/-- `CASES` 的 activation 分层；已有真实分支资源优先于单构造子结构拆解。 -/
private inductive CasesActivationPass where
  | branching
  | preferredUnary
  | demandedLogicalUnary
  | logicalUnary
  | structuralUnary
deriving BEq, Repr

private def CasesActivationPass.matches
    (pass : CasesActivationPass)
    (descriptor : HostSequentCasesDescriptor) : Bool :=
  match pass with
  | .branching =>
      decide (descriptor.expectedBranches > 1)
  | .preferredUnary =>
      descriptor.expectedBranches == 1
  | .demandedLogicalUnary
  | .logicalUnary =>
      descriptor.expectedBranches == 1 &&
        descriptor.inductiveName == ``And
  | .structuralUnary =>
      descriptor.expectedBranches == 1

/-- `FORWARD` 的 activation 分层；目标或逻辑子需求命中与普通生成分开调度。 -/
private inductive ForwardActivationPass where
  | closing
  | generated
  | demanded
  | residual
deriving BEq, Repr

/-- 当前前向实例是否消费了已经由 proof-producing rewrite 简化过的具体前提。 -/
private def forwardConsumesSimplifiedPremise
    (path : HostSequentSearchPath)
    (candidate : IndexedHostSequentForward) : Bool :=
  candidate.premises.any fun premise =>
    path.forwardSimplified.any fun simplified =>
      Expr.equal simplified premise

private def ForwardActivationPass.matches
    (pass : ForwardActivationPass)
    (path : HostSequentSearchPath)
    (candidate : IndexedHostSequentForward) : Bool :=
  let consumesSimplified :=
    forwardConsumesSimplifiedPremise path candidate
  match pass with
  | .closing =>
      candidate.closesTarget
  | .generated =>
      candidate.demandScore >= 2 && !consumesSimplified
  | .demanded =>
      candidate.demandScore > 0 &&
        (candidate.demandScore < 2 || !consumesSimplified)
  | .residual =>
      candidate.demandScore == 0 ||
        (candidate.demandScore >= 2 && consumesSimplified)

/-- `CHOOSE` 的 activation 分层；生成事实必须先于开放 rewrite 被消费。 -/
private inductive ChooseActivationPass where
  | generated
  | any
deriving BEq, Repr

private structure HostSequentScoredConstructor where
  descriptor : HostSequentConstructorDescriptor
  distance? : Option Nat
  age : Nat

/--
只准备按当前表面结论头命中、且具体实例通过局部 proof 覆盖检查的声明级规则。

目标桶通常很小；这里直接运行有界实例 checker，避免另一份头近似与 HostProp
投影资源视图不一致。
-/
private def registeredApplyCandidates
    (runtime : Runtime) (view : HostPropAnalysis.View)
    (target : Expr) :
    MetaM (Array ApplyCandidate) := do
  let mut candidates := #[]
  for rule in ← registeredHostSequentRulesForTarget target do
    let candidate : ApplyCandidate := {
      label := rule.declaration
      proof := ← mkConstWithFreshMVarLevels rule.declaration
      rank := rule.rank
    }
    if let some candidate ←
        specializeRegisteredApplyCandidate?
          runtime view target candidate then
      candidates := candidates.push candidate
  return candidates

/-- 局部 proof 与按目标结论头索引的全局注册规则共享一个候选面。 -/
private def applyCandidates
    (runtime : Runtime) (view : HostPropAnalysis.View)
    (target : Expr) (resources : Array FVarId) :
    MetaM (Array ApplyCandidate) := do
  let mut candidates := #[]
  if view.targetShape.root == .existential then
    for ranked in view.apply do
      let some resource ← runtime.analysis.resource? ranked.resource
        | continue
      if resource.projectionPath.isEmpty ||
          resource.shape.conclusionRoot != .existential then
        continue
      candidates := candidates.push {
        label := resource.label
        proof := resource.proof
      }
  for resource in resources do
    let proof := mkFVar resource
    unless candidates.any fun candidate => candidate.proof == proof do
      candidates := candidates.push {
        label := (← resource.getDecl).userName
        proof := proof
      }
  for candidate in ← registeredApplyCandidates runtime view target do
    candidates := candidates.push candidate
  return candidates

private def scoreApplyCandidate
    (runtime : Runtime) (view : HostPropAnalysis.View)
    (target : Expr) (candidate : ApplyCandidate) (age : Nat) :
    MetaM ScoredApplyCandidate := do
  let savedState ← saveState
  let result ←
    try
      let plan ← prepareHostApply candidate.proof target
      let mut exactPremises := 0
      for child in plan.children do
        let premise ← instantiateMVars (← child.getType)
        if premise.hasMVar then
          continue
        let premiseView ← runtime.analysis.query view.frame premise
        if !premiseView.exact.isEmpty then
          exactPremises := exactPremises + 1
      pure {
        candidate := candidate
        admitted := true
        exactPremises := exactPremises
        remainingPremises := plan.children.size - exactPremises
        age := age
      }
    catch _ =>
      pure {
        candidate := candidate
        age := age
      }
  savedState.restore
  return result

private def orderApplyCandidateArray
    (runtime : Runtime) (view : HostPropAnalysis.View)
    (target : Expr) (candidates : Array ApplyCandidate) :
    MetaM (Array ApplyCandidate) := do
  let mut scored := #[]
  for age in [0 : candidates.size] do
    scored := scored.push <|
      ← scoreApplyCandidate runtime view target candidates[age]! age
  let sorted :=
    scored.qsort fun left right =>
      if left.admitted != right.admitted then
        left.admitted
      else if left.exactPremises != right.exactPremises then
        left.exactPremises > right.exactPremises
      else if left.remainingPremises != right.remainingPremises then
        left.remainingPremises < right.remainingPremises
      else if left.candidate.rank != right.candidate.rank then
        left.candidate.rank > right.candidate.rank
      else
        left.age < right.age
  return sorted.map (·.candidate)

private def orderApplyCandidates
    (runtime : Runtime) (view : HostPropAnalysis.View)
    (target : Expr) (resources : Array FVarId) :
    MetaM (Array ApplyCandidate) := do
  orderApplyCandidateArray runtime view target <|
    ← applyCandidates runtime view target resources

private def orderRegisteredApplyCandidates
    (runtime : Runtime) (view : HostPropAnalysis.View)
    (target : Expr) :
    MetaM (Array ApplyCandidate) := do
  orderApplyCandidateArray runtime view target <|
    ← registeredApplyCandidates runtime view target

/--
仅当目标表面是一个会被 `whnf` 消去的命名命题时，才允许声明级规则抢在逻辑分解前。
-/
private def hasReducibleSurfaceHead (target : Expr) : MetaM Bool := do
  let target ← instantiateMVars target
  let some surface := target.consumeMData.getAppFn.constName?
    | return false
  let reduced ← whnf target
  let some reducedHead := reduced.consumeMData.getAppFn.constName?
    | return true
  return surface != reducedHead

private def relationSubsetOperands? (proposition : Expr) :
    MetaM (Option (Expr × Expr)) := do
  let (arguments, binderInfos, conclusion) ←
    forallMetaTelescopeReducing proposition
  unless arguments.size == 2 && binderInfos[1]!.isExplicit do
    return none
  let valueType ← instantiateMVars (← inferType arguments[0]!)
  if ← isProp valueType then
    return none
  let premiseType ← instantiateMVars (← inferType arguments[1]!)
  unless ← isProp premiseType do
    return none
  let conclusion ← instantiateMVars conclusion
  let premiseHead := premiseType.consumeMData.getAppFn
  let conclusionHead := conclusion.consumeMData.getAppFn
  unless Expr.equal premiseHead conclusionHead do
    return none
  let premiseArguments := premiseType.getAppArgs
  let conclusionArguments := conclusion.getAppArgs
  unless premiseArguments.size == conclusionArguments.size &&
      premiseArguments.size >= 2 do
    return none
  for index in [0 : premiseArguments.size - 1] do
    unless ← isDefEq premiseArguments[index]! conclusionArguments[index]! do
      return none
  return some (premiseArguments.back!, conclusionArguments.back!)

/--
从受阻的良序 APPLY 前提提取二元 overlap demand。

这里只识别“一个成员子集前提 + 一个已由上下文给出的非空前提”；CUT 本身由这两个
前提的普通命题形状构造，不检查候选声明名。
-/
private def overlapCutFromApplyPlan?
    (candidate : ApplyCandidate) (plan : HostApplyPlan)
    (resources : Array FVarId) :
    MetaM (Option OverlapCutCandidate) := do
  unless plan.children.size == 2 do
    return none
  let mut subsetData? : Option (Expr × Expr) := none
  let mut nonempty? : Option (MVarId × Expr) := none
  for child in plan.children do
    let proposition ← instantiateMVars (← child.getType)
    if proposition.hasMVar then
      return none
    if let some subsetData ← relationSubsetOperands? proposition then
      subsetData? := some subsetData
    else if proposition.isAppOfArity ``Exists 2 then
      nonempty? := some (child, proposition)
  let some (left, right) := subsetData?
    | return none
  let some (nonemptyGoal, nonempty) := nonempty?
    | return none
  if (← HostSequent.admitInitialRule {
        goal := nonemptyGoal
        resources := resources
      }).isNone then
    return none
  let arguments := nonempty.getAppArgs
  let domain := arguments[0]!
  let predicate := arguments[1]!
  let .lam binderName binderType body binderInfo := predicate.consumeMData
    | return none
  let bodyArguments := body.getAppArgs
  if bodyArguments.isEmpty then
    return none
  unless ← isDefEq bodyArguments.back! left do
    return none
  let rightBody :=
    mkAppN body.getAppFn <|
      bodyArguments.set! (bodyArguments.size - 1) right
  let cutBody := mkApp2 (mkConst ``And) body rightBody
  let cutPredicate := mkLambda binderName binderInfo binderType cutBody
  let cut := mkAppN nonempty.getAppFn #[domain, cutPredicate]
  let cut ← instantiateMVars cut
  if cut.hasMVar then
    return none
  return some {
    apply := candidate
    cut
    left
    right
  }

private structure OverlapBoundaryInstance where
  decomposition : Expr

private def overlapExpressionsDefEq
    (left right : Expr) : MetaM Bool := do
  let savedState ← saveState
  let result ←
    try
      isDefEq left right
    catch _ =>
      pure false
  savedState.restore
  return result

/--
从局部资源中寻找 overlap transfer 的边界分解。

第一条资源把当前 left 成员送入某个 ambient；第二条资源在同一对象上把 ambient
成员分解为 right 成员或一个桥接命题。这里只检查应用后的命题形状。
-/
private def overlapBoundaryInstance?
    (resources : Array FVarId) (value leftProof rightMembership : Expr) :
    MetaM (Option OverlapBoundaryInstance) := do
  let lctx ← getLCtx
  for subsetResource in resources do
    unless lctx.contains subsetResource do
      continue
    let ambient? ←
      try
        let proof :=
          mkApp (mkApp (mkFVar subsetResource) value) leftProof
        let proposition ← instantiateMVars (← inferType proof)
        if proposition.hasMVar || !(← isProp proposition) then
          pure none
        else
          pure (some (proof, proposition))
      catch _ =>
        pure none
    let some (ambientProof, ambientMembership) := ambient?
      | continue
    for boundaryResource in resources do
      unless lctx.contains boundaryResource do
        continue
      let boundary? ←
        try
          let boundaryAt := mkApp (mkFVar boundaryResource) value
          let boundaryType ← instantiateMVars (← whnf (← inferType boundaryAt))
          if boundaryType.hasMVar ||
              !boundaryType.isAppOfArity ``Iff 2 then
            pure none
          else
            let sides := boundaryType.getAppArgs
            let forward ←
              overlapExpressionsDefEq sides[0]! ambientMembership
            let reverse ←
              overlapExpressionsDefEq sides[1]! ambientMembership
            let disjunction? :=
              if forward then some sides[1]!
              else if reverse then some sides[0]!
              else none
            let some disjunction := disjunction?
              | pure none
            let disjunction ← whnf disjunction
            if !disjunction.isAppOfArity ``Or 2 then
              pure none
            else
              let alternatives := disjunction.getAppArgs
              let rightFirst ←
                overlapExpressionsDefEq alternatives[0]! rightMembership
              let rightSecond ←
                overlapExpressionsDefEq alternatives[1]! rightMembership
              if !rightFirst && !rightSecond then
                pure none
              else
                let decomposition ←
                  if forward then
                    mkAppM ``Iff.mp #[boundaryAt, ambientProof]
                  else
                    mkAppM ``Iff.mpr #[boundaryAt, ambientProof]
                let decomposition ← instantiateMVars decomposition
                if decomposition.hasMVar then
                  pure none
                else
                  pure (some { decomposition })
        catch _ =>
          pure none
      if let some boundary := boundary? then
        return some boundary
  return none

private def overlapBridgeTransfer?
    (bridge witness candidateRight targetRight : Expr) :
    MetaM (Option Expr) := do
  let result? ←
    try
      let bridgeAt := mkApp bridge witness
      let bridgeType ← instantiateMVars (← whnf (← inferType bridgeAt))
      if bridgeType.hasMVar || !bridgeType.isAppOfArity ``Iff 2 then
        pure none
      else
        let sides := bridgeType.getAppArgs
        let candidateRightType ←
          instantiateMVars (← inferType candidateRight)
        let candidateOnLeft ←
          overlapExpressionsDefEq sides[0]! candidateRightType
        let targetOnRight ←
          overlapExpressionsDefEq sides[1]! targetRight
        let candidateOnRight ←
          overlapExpressionsDefEq sides[1]! candidateRightType
        let targetOnLeft ←
          overlapExpressionsDefEq sides[0]! targetRight
        if candidateOnLeft && targetOnRight then
          some <$> mkAppM ``Iff.mp #[bridgeAt, candidateRight]
        else if candidateOnRight && targetOnLeft then
          some <$> mkAppM ``Iff.mpr #[bridgeAt, candidateRight]
        else
          pure none
    catch _ =>
      pure none
  result?.mapM instantiateMVars

/--
用 intersection 上的最小元证明直接闭合原始 overlap 目标。

该过程只消费当前 proof 资源和 generator 给出的定义等价；所有中间结果都直接赋给
Lean metavariable，搜索失败时由外层事务恢复。
-/
private unsafe def closeOverlapTransfer
    (runtime : Runtime) (goal : MVarId) (resources : Array FVarId)
    (definitionProof witness candidateLeft candidateRight least : Expr)
    (depth : Nat) : TacticM Unit := do
  setGoals [goal]
  runtime.visit depth
  witnessHostTargetExpr witness
  splitHostTarget
  let (candidateGoal, minimalGoal) ←
    match ← getGoals with
    | [candidateGoal, minimalGoal] =>
        pure (candidateGoal, minimalGoal)
    | _ =>
        throwError "focused sequent overlap transfer expected two conjunction goals"
  runtime.addBranchChildren 2
  candidateGoal.withContext do
    let target ← instantiateMVars (← candidateGoal.getType)
    let proofType ← instantiateMVars (← inferType candidateLeft)
    unless ← isDefEq target proofType do
      throwError
        "focused sequent overlap candidate does not inhabit the left relation"
    candidateGoal.assign candidateLeft
  let (valueId, minimalGoal) ← minimalGoal.intro1P
  let (leftId, minimalGoal) ← minimalGoal.intro1P
  let value := mkFVar valueId
  let leftProof := mkFVar leftId
  let (definitionAt, rightMembership, targetRight, boundary) ←
      minimalGoal.withContext do
    let definitionAt := mkApp definitionProof value
    let definitionType ←
      instantiateMVars (← whnf (← inferType definitionAt))
    unless definitionType.isAppOfArity ``Iff 2 do
      throwError
        "focused sequent overlap generator lost its defining equivalence"
    let conjunction ← whnf definitionType.getAppArgs[1]!
    unless conjunction.isAppOfArity ``And 2 do
      throwError
        "focused sequent overlap generator lost its binary conjunction"
    let rightMembership := conjunction.getAppArgs[1]!
    let target ← instantiateMVars (← whnf (← minimalGoal.getType))
    unless target.isAppOfArity ``Or 2 do
      throwError
        "focused sequent overlap transfer expected an ordered disjunction"
    let targetRight := target.getAppArgs[1]!
    let some boundary ←
        overlapBoundaryInstance? resources value leftProof rightMembership
      | throwError
          "focused sequent overlap transfer found no ambient boundary decomposition"
    return (definitionAt, rightMembership, targetRight, boundary)
  let decompositionName ← mkFreshUserName `overlapBoundary
  let (decompositionId, casesGoal) ←
    minimalGoal.note decompositionName boundary.decomposition
  let branches ← casesGoal.cases decompositionId
  unless branches.size == 2 do
    throwError "focused sequent overlap boundary expected exactly two branches"
  runtime.addBranchChildren 2
  for branch in branches do
    let some branchProof := branch.fields.back?
      | throwError "focused sequent overlap boundary branch lost its proof"
    branch.mvarId.withContext do
      let branchType ← instantiateMVars (← inferType branchProof)
      if ← overlapExpressionsDefEq branchType rightMembership then
        let pair ← mkAppM ``And.intro #[leftProof, branchProof]
        let generatedMembership ←
          mkAppM ``Iff.mpr #[definitionAt, pair]
        let result :=
          mkApp (mkApp least value) generatedMembership
        let target ← instantiateMVars (← branch.mvarId.getType)
        let resultType ← instantiateMVars (← inferType result)
        unless ← isDefEq target resultType do
          throwError
            "focused sequent overlap least branch does not match the target"
        branch.mvarId.assign result
      else
        let some transferred ←
            overlapBridgeTransfer?
              branchProof witness candidateRight targetRight
          | throwError
              "focused sequent overlap bridge cannot transport right membership"
        let target ← instantiateMVars (← whnf (← branch.mvarId.getType))
        let arguments := target.getAppArgs
        let result :=
          mkApp3 (mkConst ``Or.inr) arguments[0]! arguments[1]! transferred
        branch.mvarId.assign result
  runtime.modify fun stats => {
    stats with
    overlapPositiveTransfers := stats.overlapPositiveTransfers + 1
  }
  setGoals []

private def overlapNonemptyResource?
    (resources : Array FVarId) (cut : Expr) :
    MetaM (Option FVarId) := do
  let cut ← instantiateMVars (← whnf cut)
  unless cut.isAppOfArity ``Exists 2 do
    return none
  let cutArguments := cut.getAppArgs
  let domain := cutArguments[0]!
  let cutPredicate := cutArguments[1]!
  let lctx ← getLCtx
  for resource in resources do
    unless lctx.contains resource do
      continue
    let resourceType ← instantiateMVars (← whnf (← resource.getType))
    unless resourceType.isAppOfArity ``Exists 2 do
      continue
    let arguments := resourceType.getAppArgs
    unless ← overlapExpressionsDefEq arguments[0]! domain do
      continue
    let isMatching ← withLocalDeclD `overlapValue domain fun value => do
      let cutBody ← whnf (mkApp cutPredicate value)
      unless cutBody.isAppOfArity ``And 2 do
        return false
      let resourceBody ← whnf (mkApp arguments[1]! value)
      overlapExpressionsDefEq cutBody.getAppArgs[0]! resourceBody
    if isMatching then
      return some resource
  return none

private def overlapBridgeFromBoundary?
    (cut negativeProof : Expr) (resources : Array FVarId)
    (value leftProof rightMembership : Expr) :
    MetaM (Option Expr) := do
  let some boundary ←
      overlapBoundaryInstance? resources value leftProof rightMembership
    | return none
  let decompositionType ←
    instantiateMVars (← whnf (← inferType boundary.decomposition))
  unless decompositionType.isAppOfArity ``Or 2 do
    return none
  let alternatives := decompositionType.getAppArgs
  let rightFirst ←
    overlapExpressionsDefEq alternatives[0]! rightMembership
  let rightSecond ←
    overlapExpressionsDefEq alternatives[1]! rightMembership
  if !rightFirst && !rightSecond then
    return none
  let bridgeType :=
    if rightFirst then alternatives[1]! else alternatives[0]!
  let cut ← instantiateMVars (← whnf cut)
  let cutArguments := cut.getAppArgs
  let domain := cutArguments[0]!
  let predicate := cutArguments[1]!
  let level := (← inferType domain).sortLevel!
  let eliminateRight ← withLocalDeclD `right rightMembership fun rightProof => do
    let pair ← mkAppM ``And.intro #[leftProof, rightProof]
    let cutWitness :=
      mkAppN (mkConst ``Exists.intro [level])
        #[domain, predicate, value, pair]
    let contradiction := mkApp negativeProof cutWitness
    let resultLevel := (← inferType bridgeType).sortLevel!
    let result :=
      mkApp2 (mkConst ``False.elim [resultLevel]) bridgeType contradiction
    mkLambdaFVars #[rightProof] result
  let keepBridge ← withLocalDeclD `bridge bridgeType fun bridgeProof =>
    mkLambdaFVars #[bridgeProof] bridgeProof
  let leftBranch := if rightFirst then eliminateRight else keepBridge
  let rightBranch := if rightFirst then keepBridge else eliminateRight
  let result ←
    mkAppM ``Or.elim #[boundary.decomposition, leftBranch, rightBranch]
  let result ← instantiateMVars result
  if result.hasMVar then return none else return some result

private def composeOverlapBridges?
    (candidateBridge valueBridge target : Expr) :
    MetaM (Option Expr) := do
  let target ← instantiateMVars (← whnf target)
  let .forallE binderName binderType body binderInfo := target
    | return none
  withLocalDecl binderName binderInfo binderType fun member => do
    let candidateAt := mkApp candidateBridge member
    let valueAt := mkApp valueBridge member
    let valueSymm ← mkAppM ``Iff.symm #[valueAt]
    let transitive ← mkAppM ``Iff.trans #[candidateAt, valueSymm]
    let targetBody := body.instantiate1 member
    let proofType ← instantiateMVars (← inferType transitive)
    unless ← overlapExpressionsDefEq proofType targetBody do
      return none
    some <$> mkLambdaFVars #[member] transitive

/--
闭合 overlap CUT 的否定分支。

无 overlap 会把每个 left 成员的 boundary 分解强制到 bridge 分支；两个以 right 为公共
端点的 bridge 再逐点合成为原目标关系。
-/
private unsafe def closeOverlapNegativeTransfer
    (runtime : Runtime) (goal : MVarId) (negativeProof : FVarId)
    (candidate : OverlapCutCandidate) (resources : Array FVarId)
    (depth : Nat) : TacticM Unit := do
  setGoals [goal]
  runtime.visit depth
  let nonemptyResource ← goal.withContext do
    let some resource ←
        overlapNonemptyResource? resources candidate.cut
      | throwError
          "focused sequent overlap negative branch found no left nonempty resource"
    return resource
  let witnessName ← mkFreshUserName `overlapNegativeWitness
  let leftName ← mkFreshUserName `overlapNegativeLeft
  chooseHostProofId nonemptyResource witnessName leftName
  let (witness, candidateLeft) ← withMainContext do
    return (
      mkFVar (← getLocalDeclFromUserName witnessName).fvarId,
      mkFVar (← getLocalDeclFromUserName leftName).fvarId)
  let transferGoal ← getMainGoal
  witnessHostTargetExpr witness
  splitHostTarget
  let (candidateGoal, minimalGoal) ←
    match ← getGoals with
    | [candidateGoal, minimalGoal] =>
        pure (candidateGoal, minimalGoal)
    | _ =>
        throwError
          "focused sequent overlap negative transfer expected two conjunction goals"
  runtime.addBranchChildren 2
  candidateGoal.withContext do
    let target ← instantiateMVars (← candidateGoal.getType)
    let proofType ← instantiateMVars (← inferType candidateLeft)
    unless ← isDefEq target proofType do
      throwError
        "focused sequent overlap negative witness left proof does not match"
    candidateGoal.assign candidateLeft
  let (valueId, minimalGoal) ← minimalGoal.intro1P
  let (leftId, minimalGoal) ← minimalGoal.intro1P
  minimalGoal.withContext do
    let value := mkFVar valueId
    let valueLeft := mkFVar leftId
    let cut ← instantiateMVars (← whnf candidate.cut)
    let cutPredicate := cut.getAppArgs[1]!
    let candidateCutBody ← whnf (mkApp cutPredicate witness)
    let valueCutBody ← whnf (mkApp cutPredicate value)
    unless candidateCutBody.isAppOfArity ``And 2 &&
        valueCutBody.isAppOfArity ``And 2 do
      throwError "focused sequent overlap negative CUT lost its conjunction"
    let candidateRight := candidateCutBody.getAppArgs[1]!
    let valueRight := valueCutBody.getAppArgs[1]!
    let negative := mkFVar negativeProof
    let some candidateBridge ←
        overlapBridgeFromBoundary? candidate.cut negative resources
          witness candidateLeft candidateRight
      | throwError
          "focused sequent overlap negative branch cannot derive the witness bridge"
    let some valueBridge ←
        overlapBridgeFromBoundary? candidate.cut negative resources
          value valueLeft valueRight
      | throwError
          "focused sequent overlap negative branch cannot derive the value bridge"
    let target ← instantiateMVars (← whnf (← minimalGoal.getType))
    unless target.isAppOfArity ``Or 2 do
      throwError
        "focused sequent overlap negative transfer expected an ordered disjunction"
    let targetArguments := target.getAppArgs
    let some relation ←
        composeOverlapBridges?
          candidateBridge valueBridge targetArguments[0]!
      | throwError
          "focused sequent overlap negative bridges do not compose into the target"
    let result :=
      mkApp3 (mkConst ``Or.inl)
        targetArguments[0]! targetArguments[1]! relation
    minimalGoal.assign result
  runtime.modify fun stats => {
    stats with
    overlapNegativeTransfers := stats.overlapNegativeTransfers + 1
  }
  setGoals []
  trace[YesMetaZFC.proveAuto.sequent]
    "overlap.transfer.negative depth={depth}; witness={witnessName}; \
    target={← transferGoal.getType}"

/-!
Vampire 的完整 literal selection 会在满足完备性约束的候选中优先选择质量更高的 literal。
宿主相继式的正相位对应目标构造子：这里用一个有界、事务式的纯构造可达性探针估计
“离当前显式资源还有几层安全构造”。它只改变候选顺序，不删除候选，也不消费搜索预算。
-/
private partial def reflexiveTargetDistance?
    (target : Expr) (fuel : Nat) : MetaM (Option Nat) := do
  let target ← whnf (← instantiateMVars target)
  if target.hasMVar then
    return none
  if target.isAppOfArity ``Eq 3 then
    let arguments := target.getAppArgs
    if ← hostExpressionsDefEq arguments[1]! arguments[2]! then
      return some 1
  if target.isAppOfArity ``Iff 2 then
    let arguments := target.getAppArgs
    if ← hostExpressionsDefEq arguments[0]! arguments[1]! then
      return some 1
  if fuel == 0 then
    return none
  let .forallE binderName domain body binderInfo := target
    | return none
  if ← isProp domain then
    return none
  withLocalDecl binderName binderInfo domain fun value => do
    return (← reflexiveTargetDistance? (body.instantiate1 value) (fuel - 1)).map (· + 1)

private partial def constructorInitialDistance?
    (goal : MVarId) (resources : Array FVarId) (fuel : Nat) :
    MetaM (Option Nat) := do
  let exactInitial ← goal.withContext do
    let declaration ← goal.getDecl
    let target ← instantiateMVars declaration.type
    if target.hasMVar then
      return false
    for resource in resources do
      unless declaration.lctx.contains resource do
        continue
      let proposition ← instantiateMVars (← resource.getType)
      if proposition.hasMVar then
        continue
      if Expr.equal proposition.consumeMData target.consumeMData then
        return true
    return false
  if exactInitial then
    return some 0
  if fuel == 0 then
    return none
  let target ← instantiateMVars (← goal.getType)
  if target.hasMVar then
    return none
  if let some distance ← reflexiveTargetDistance? target fuel then
    return some distance
  let constructors ← targetHostSequentConstructors target
  let mut best? : Option Nat := none
  for descriptor in constructors do
    let savedState ← saveState
    let distance? ←
      try
        let proof ← mkConstWithFreshMVarLevels descriptor.constructorName
        let plan ← prepareHostApply proof target
        let mut distance := 1
        let mut reachable := true
        for child in plan.children do
          let some childDistance ←
              constructorInitialDistance? child resources (fuel - 1)
            | reachable := false
              break
          distance := distance + childDistance
        pure <| if reachable then some distance else none
      catch _ =>
        pure none
    savedState.restore
    if let some distance := distance? then
      best? :=
        match best? with
        | some best => some (min best distance)
        | none => some distance
  return best?

private def constructorCandidateDistance?
    (target : Expr) (resources : Array FVarId)
    (descriptor : HostSequentConstructorDescriptor) :
    MetaM (Option Nat) := do
  let savedState ← saveState
  let distance? ←
    try
      let proof ← mkConstWithFreshMVarLevels descriptor.constructorName
      let plan ← prepareHostApply proof target
      let mut distance := 1
      let mut reachable := true
      for child in plan.children do
        let some childDistance ← constructorInitialDistance? child resources 3
          | reachable := false
            break
        distance := distance + childDistance
      pure <| if reachable then some distance else none
    catch _ =>
      pure none
  savedState.restore
  return distance?

private def orderConstructorCandidates
    (runtime : Runtime) (goal : MVarId) (target : Expr)
    (resources : Array FVarId)
    (constructors : Array HostSequentConstructorDescriptor) :
    TacticM (Array HostSequentScoredConstructor) := do
  let mut scored := #[]
  for h : position in [:constructors.size] do
    let descriptor := constructors[position]
    let distance? ←
      goal.withContext <|
        constructorCandidateDistance? target resources descriptor
    runtime.modify fun stats => {
      stats with
      constructorSelectorProbes := stats.constructorSelectorProbes + 1
      constructorSelectorGuided :=
        stats.constructorSelectorGuided + if distance?.isSome then 1 else 0
    }
    scored := scored.push {
      descriptor := descriptor
      distance? := distance?
      age := position
    }
  return scored.qsort fun left right =>
    match left.distance?, right.distance? with
    | some leftDistance, some rightDistance =>
        if leftDistance == rightDistance then
          left.age < right.age
        else
          leftDistance < rightDistance
    | some _, none => true
    | none, some _ => false
    | none, none => left.age < right.age

private def localFVarPosition?
    (fvarId : FVarId) : MetaM (Option Nat) := do
  let mut position := 0
  for declaration in (← getLCtx) do
    if declaration.fvarId == fvarId then
      return some position
    position := position + 1
  return none

private def hostObjectSubstitutionOrientation?
    (equality : FVarId) : MetaM (Option Bool) := do
  let proposition ← whnf (← instantiateMVars (← equality.getType))
  unless (← getMVarsNoDelayed proposition).isEmpty do
    return none
  let some (_, lhs, rhs) ← matchEq? proposition
    | return none
  -- CHOOSE/CASES 产生的局部对象可能带可展开值；替换规则必须优先保留其 FVar 身份。
  let lhs := lhs.consumeMData
  let rhs := rhs.consumeMData
  let lhs ← if lhs.isFVar then pure lhs else whnf lhs
  let rhs ← if rhs.isFVar then pure rhs else whnf rhs
  let lhs := lhs.consumeMData
  let rhs := rhs.consumeMData
  let lhsObject? ←
    match lhs.fvarId? with
    | none => pure none
    | some fvarId =>
        if ← isProp (← fvarId.getType) then pure none else pure (some fvarId)
  let rhsObject? ←
    match rhs.fvarId? with
    | none => pure none
    | some fvarId =>
        if ← isProp (← fvarId.getType) then pure none else pure (some fvarId)
  match lhsObject?, rhsObject? with
  | some lhsId, some rhsId =>
      let lhsPosition := (← localFVarPosition? lhsId).getD 0
      let rhsPosition := (← localFVarPosition? rhsId).getD 0
      -- `symm=false` 消去左侧；优先消去较新的局部对象。
      return some (rhsPosition > lhsPosition)
  | some _, none =>
      return some false
  | none, some _ =>
      return some true
  | none, none =>
      return none

private def remapSubstitutedResources
    (goal : MVarId) (resources : Array FVarId)
    (equality : FVarId) (substitution : FVarSubst) :
    MetaM (Array FVarId) := goal.withContext do
  let declaration ← goal.getDecl
  let mut result := #[]
  for resource in resources do
    if resource == equality then
      continue
    let mappedExpression :=
      (substitution.find? resource).getD (mkFVar resource)
    let some mapped := mappedExpression.fvarId?
      | throwError
          "focused sequent substitution mapped a proof resource to a non-FVar term"
    unless declaration.lctx.contains mapped do
      throwError
        "focused sequent substitution retained a stale proof resource"
    let proposition ← instantiateMVars (← mapped.getType)
    if proposition.hasMVar || !(← isProp proposition) then
      throwError
        "focused sequent substitution produced an unstable proof resource"
    unless result.contains mapped do
      result := result.push mapped
  return result

private unsafe def prepareBranchIndex?
    (runtime : Runtime) (goal : MVarId) (target : Expr)
    (resources : Array FVarId) (depth : Nat)
    (generated : Array Expr) :
    TacticM (Option HostSequentBranchIndex) := do
  let branchState ← saveState
  try
    let index ←
      prepareHostSequentBranchIndex target resources
        runtime.config.maxForwardCandidates
        runtime.config.maxWitnessCandidates generated
    runtime.modify fun stats => {
      stats with branchIndexPreparations := stats.branchIndexPreparations + 1
    }
    return some index
  catch error =>
    branchState.restore
    runtime.rethrowBudgetAbort
    runtime.modify fun stats => {
      stats with branchIndexFailures := stats.branchIndexFailures + 1
    }
    trace[YesMetaZFC.proveAuto.sequent]
      "branch-index.failed depth={depth}; reason={error.toMessageData}"
    setGoals [goal]
    return none

mutual

  /--
  搜索一个当前主目标。

  该函数直接运行 Lean Meta 操作，但不属于可信边界：失败候选完整恢复状态，成功证明
  仍由当前目标的 metavariable assignment 和 Lean 内核验证。
  -/
  private unsafe def solveCurrent
      (runtime : Runtime) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Unit := do
    runtime.visit depth
    let initialGoal ← getMainGoal
    let initialResources ← withMainContext localProofResources
    let normalized ←
      HostNormalization.CheckedTransaction.run
        initialGoal initialResources runtime.prepared
          runtime.config.normalization
    let normalized ←
      match normalized with
      | .rolledBack journal =>
          runtime.recordNormalization journal false false
          trace[YesMetaZFC.proveAuto.normalization]
            "transaction.rollback depth={depth}; \
            calls={journal.checkedClosures}; nodes={journal.nodes}; \
            validated={journal.resultValidatedClosures}; \
            noOp={journal.noOpClosures}; \
            replayPruned={journal.noOpReplayPrunes}; \
            replayed={journal.replayedClosures}; \
            attempts={journal.attempts}; backtracks={journal.backtracks}; \
            conservative={journal.conservativeEdges}/\
            {journal.conservativeAttempts}; \
            phaseQueries={journal.phaseQueries}; \
            emptyPhasePrunes={journal.emptyPhasePrunes}; \
            reason={journal.rollbackReason?.getD "unknown"}"
          throwError
            "focused sequent checked normalization rolled back at depth \
            {depth}: {journal.rollbackReason?.getD "unknown"}"
      | .committed result =>
          runtime.recordNormalization
            result.journal result.changed result.goal?.isNone
          trace[YesMetaZFC.proveAuto.normalization]
            "transaction.commit depth={depth}; changed={result.changed}; \
            discharged={result.goal?.isNone}; \
            hypotheses={result.journal.hypothesesChanged}/\
            {result.journal.hypothesisCandidates}; \
            skipped={result.journal.hypothesesSkipped}; \
            cleared={result.journal.hypothesesCleared}; \
            remapped={result.journal.resourcesRemapped}; \
            validated={result.journal.resultValidatedClosures}; \
            noOp={result.journal.noOpClosures}; \
            replayPruned={result.journal.noOpReplayPrunes}; \
            replayed={result.journal.replayedClosures}; \
            nodes={result.journal.nodes}; \
            attempts={result.journal.attempts}; \
            backtracks={result.journal.backtracks}; \
            conservative={result.journal.conservativeEdges}/\
            {result.journal.conservativeAttempts}; \
            phaseQueries={result.journal.phaseQueries}; \
            emptyPhasePrunes={result.journal.emptyPhasePrunes}; \
            cycles={result.journal.cycles}; \
            path={normalizationPathCount result.journal}; \
            candidates={result.journal.candidateRules}; \
            indexQueries={result.journal.indexQueries}; \
            indexedCandidates={result.journal.indexedCandidates}; \
            rewrites={result.journal.rewrites}; \
            checker={normalizationCheckerPasses result.journal}/\
            {result.journal.replayedClosures}; \
            replayedSteps={normalizationReplayedSteps result.journal}; \
            closureNs={result.journal.closureElapsedNs}; \
            resultValidateNs={result.journal.resultValidationNs}; \
            payloadNs={result.journal.payloadElapsedNs}; \
            checkerNs={result.journal.checkerElapsedNs}; \
            snapshotNs={result.journal.snapshotElapsedNs}; \
            proofReplayNs={result.journal.proofReplayElapsedNs}; \
            artifactValidateNs={result.journal.artifactValidationNs}; \
            applicationNs={result.journal.applicationElapsedNs}; \
            provider={result.journal.providerCalls}; \
            elapsedNs={result.journal.elapsedNs}; \
            used={normalizationUsedDeclarations result.journal}"
          pure result
    let some goal := normalized.goal?
      | setGoals []
        return
    setGoals [goal]
    let resources := normalized.resources
    let target ← withMainContext do
      instantiateMVars (← getMainTarget)
    let fingerprint? ←
      withMainContext <| makeHostSequentFingerprint? target resources
    let path ←
      match fingerprint? with
      | some fingerprint =>
          if fingerprintOnPath path.fingerprints fingerprint then
            runtime.modify fun stats => {
              stats with cyclePrunes := stats.cyclePrunes + 1
            }
            throwError
              "focused sequent pruned a repeated normalized state"
          pure {
            path with
            fingerprints := path.fingerprints.push fingerprint
          }
      | none =>
          pure path
    if let some step ← HostSequent.tryInitialRule {
        goal := goal
        resources := resources
      } then
      let resourceLabel ← goal.withContext <|
        renderResourceLabel step.resource
      runtime.modify fun stats => {
        stats with initialRuleClosures := stats.initialRuleClosures + 1
      }
      trace[YesMetaZFC.proveAuto.sequent]
        "initial.closed depth={depth}; resource={resourceLabel}"
      setGoals []
      return
    let analysisView ← goal.withContext do
      let frame ← runtime.analysis.fromLocalContext
      runtime.analysis.query frame target
    if let some resource ←
        tryProjectedInitialRule runtime goal analysisView then
      runtime.modify fun stats => {
        stats with initialRuleClosures := stats.initialRuleClosures + 1
      }
      trace[YesMetaZFC.proveAuto.sequent]
        "initial.projected depth={depth}; source={resource.sourceLabel}; \
        projection={resource.projectionPath}"
      setGoals []
      return
    if let some resourceLabel ← tryFalseInitialRule goal then
      runtime.modify fun stats => {
        stats with initialRuleClosures := stats.initialRuleClosures + 1
      }
      trace[YesMetaZFC.proveAuto.sequent]
        "initial.false depth={depth}; resource={resourceLabel}"
      setGoals []
      return
    let reducibleSurface ←
      withMainContext <| hasReducibleSurfaceHead target
    if reducibleSurface then
      if ←
          tryApplyCandidates
            runtime goal resources analysisView target depth path .surface then
        return
    if let some introKind ← withMainContext <| introKind? target then
      let child ←
        match introKind with
        | .implication =>
            pure (← goal.intro1P).2
        | .objectBinder baseName =>
            let name ← mkFreshUserName baseName
            pure (← goal.intro name).2
      runtime.modify fun stats => {
        stats with introSteps := stats.introSteps + 1
      }
      trace[YesMetaZFC.proveAuto.sequent]
        "intro.step depth={depth}; target={target}"
      setGoals [child]
      solveCurrent runtime (depth + 1) (resetRewriteStreak path)
      return
    if ← trySplitTarget runtime goal resources depth path then
      return
    if !reducibleSurface then
      if ←
          tryApplyCandidates
            runtime goal resources analysisView target depth path .surface then
        return
    if analysisView.signals.constructorTarget then
      if ← tryProjectedChooseCandidates
          runtime goal resources target depth path then
        return
    let earlyBranchIndex? ←
      if analysisView.targetShape.root == .disjunction &&
          analysisView.signals.casesAvailable then
        prepareBranchIndex? runtime goal target resources depth path.generated
      else
        pure none
    let earlyBranchingCasesTried ←
      match earlyBranchIndex? with
      | none =>
          pure false
      | some index =>
          let applicable :=
            index.cases.any fun candidate =>
              candidate.descriptor.expectedBranches > 1
          if applicable then
            trace[YesMetaZFC.proveAuto.sequent]
              "activation.focused depth={depth}; pass=targetDisjunctionCases"
            if ←
                tryCasesCandidates
                  runtime goal resources depth path index .branching then
              return
          pure applicable
    if ← tryGuidedTargetConstructorCandidates
        runtime goal resources target depth path then
      return
    if ← trySubstitutionCandidates
        runtime goal resources depth path then
      return
    if ← tryProjectedSubstitutionCandidates
        runtime goal resources analysisView depth path then
      return
    if ←
        tryPreferredWitnessCandidate
          runtime goal resources depth path then
      return
    if path.preferGeneratedRewrite then
      if ←
          tryRewriteCandidates
            runtime goal analysisView depth path then
        return
      if ←
          tryForwardRewriteCandidates
            runtime goal resources analysisView target depth path then
        return
    let generatedBranchIndex? ←
      if path.generated.isEmpty then
        pure none
      else
        prepareBranchIndex?
          runtime goal target resources depth path.generated
    if let some generatedIndex := generatedBranchIndex? then
      if !path.preferGeneratedRewrite &&
          generatedIndex.forward.any fun candidate =>
            ForwardActivationPass.generated.matches path candidate then
        trace[YesMetaZFC.proveAuto.sequent]
          "activation.focused depth={depth}; pass=generatedExistentialForward"
        if ←
            tryForwardCandidates
              runtime goal resources depth path generatedIndex .generated then
          return
      if generatedIndex.choose.any fun candidate =>
          generationOnPath path candidate.candidate.proposition then
        trace[YesMetaZFC.proveAuto.sequent]
          "activation.focused depth={depth}; pass=generatedChoose"
        if ←
            tryChooseCandidates
              runtime goal resources depth path generatedIndex .generated then
          return
      if let some preferred := path.preferredCases.back? then
        if generatedIndex.cases.any fun candidate =>
            candidate.descriptor.expectedBranches == 1 &&
              generationOnPath path candidate.candidate.proposition &&
              Expr.equal candidate.candidate.proof preferred then
          trace[YesMetaZFC.proveAuto.sequent]
            "activation.focused depth={depth}; pass=generatedPreferredCases"
          if ←
              tryCasesCandidates runtime goal resources depth path
                generatedIndex .preferredUnary then
            return
    let preRewriteBranchIndex? ←
      match earlyBranchIndex? with
      | some index =>
          pure (some index)
      | none =>
          match generatedBranchIndex? with
          | some index =>
              pure (some index)
          | none =>
              prepareBranchIndex?
                runtime goal target resources depth path.generated
    if let some preRewriteBranchIndex := preRewriteBranchIndex? then
      if preRewriteBranchIndex.forward.any fun candidate =>
          candidate.closesTarget then
        trace[YesMetaZFC.proveAuto.sequent]
          "activation.focused depth={depth}; pass=closingForward"
        if ←
            tryForwardCandidates runtime goal resources depth path
              preRewriteBranchIndex .closing then
          return
    let deferRewrites := path.rewriteStreak >= 2
    if deferRewrites then
      runtime.modify fun stats => {
        stats with
        rewriteDeferrals := stats.rewriteDeferrals + 1
        maxRewriteStreak := Nat.max stats.maxRewriteStreak path.rewriteStreak
      }
      trace[YesMetaZFC.proveAuto.sequent]
        "rewrite.defer depth={depth}; streak={path.rewriteStreak}"
    else if !path.preferGeneratedRewrite then
      if ←
          tryRewriteCandidates
            runtime goal analysisView depth path then
        return
      if ←
          tryForwardRewriteCandidates
            runtime goal resources analysisView target depth path then
        return
    let branchIndex? := preRewriteBranchIndex?
    if let some branchIndex := branchIndex? then
      if ← trySpecializeCandidates
          runtime goal resources depth path branchIndex then
        return
      if ← tryTransportCandidates
          runtime goal resources depth path branchIndex then
        return
    if ←
        tryApplyCandidates
          runtime goal resources analysisView target depth path .probe then
      return
    if ←
        tryOverlapCutCandidates
          runtime goal resources analysisView target depth path then
      return
    if let some branchIndex := branchIndex? then
      if ← tryFocusedActivationCandidates
          runtime goal resources depth path branchIndex
            earlyBranchingCasesTried then
        return
      if ← tryContradictionCandidates
          runtime goal depth branchIndex then
        return
      if ← tryResidualActivationCandidates
          runtime goal resources target depth path branchIndex then
        return
      if ← tryWitnessCandidates
          runtime goal resources depth path branchIndex then
        return
    if deferRewrites then
      if ←
          tryRewriteCandidates
            runtime goal analysisView depth path then
        return
      if ←
          tryForwardRewriteCandidates
            runtime goal resources analysisView target depth path then
        return
    if ←
        tryApplyCandidates
          runtime goal resources analysisView target depth path .fallback then
      return
    if let some branchIndex := branchIndex? then
      if ←
          tryUnaryCasesCandidates runtime goal resources depth path branchIndex then
        return
    trace[YesMetaZFC.proveAuto.sequent]
      "terminal.start depth={depth}; target={target}; resources={resources.size}"
    match ← tryCloseHostProofTerminal "FOCUSED SEQUENT" {
        goal := goal
        resources := resources
      } with
    | .closed terminal =>
        runtime.recordTerminal terminal true
        trace[YesMetaZFC.proveAuto.sequent]
          "terminal.closed depth={depth}; providerCalls={terminal.providerCalls}; \
          providerBuilds={terminal.providerBuilds}; providerSkips={terminal.providerSkips}; \
          contextPreparations={terminal.contextPreparations}; \
          summaryEvaluations={terminal.summaryEvaluations}"
        return
    | .failed terminal message =>
        runtime.recordTerminal terminal false
        trace[YesMetaZFC.proveAuto.sequent]
          "terminal.failed depth={depth}; providerCalls={terminal.providerCalls}; \
          providerBuilds={terminal.providerBuilds}; providerSkips={terminal.providerSkips}; \
          contextPreparations={terminal.contextPreparations}; \
          summaryEvaluations={terminal.summaryEvaluations}"
        throwError
          "focused sequent checked terminal failed for\
          {indentExpr target}\n{message}"

  /-- 对顶层 And/Iff 执行可逆 SPLIT，并递归闭合全部子相继式。 -/
  private unsafe def trySplitTarget
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Bool := do
    let applicable ← goal.withContext do
      let target ← whnf (← goal.getType)
      let head := target.getAppFn.constName?
      return head == some ``And || head == some ``Iff
    unless applicable do
      return false
    runtime.modify fun stats => {
      stats with splitCandidates := stats.splitCandidates + 1
    }
    let branchBudgetBefore ← runtime.branchBudgetCheckpoint
    let savedState ← saveState
    let mut expanded := false
    try
      let children ←
        expandHostProofStep #[{ goal := goal, resources := resources }]
          .split splitHostTarget
      expanded := true
      runtime.addBranchChildren children.size
      let isMainBranch ←
        runtime.claimMainBranchFrontier depth children.size
      trace[YesMetaZFC.proveAuto.sequent]
        "split.try depth={depth}; branches={children.size}"
      for index in [0 : children.size] do
        let some child := children[index]?
          | throwError "focused sequent SPLIT lost child {index + 1}"
        setGoals [child.goal]
        solveCurrent runtime (depth + 1) (resetRewriteStreak path)
        if index + 1 < children.size then
          runtime.rewardClosedMainBranch isMainBranch
      runtime.modify fun stats => {
        stats with
        splitSteps := stats.splitSteps + 1
        generatedPremises := stats.generatedPremises + children.size
      }
      setGoals []
      return true
    catch _ =>
      savedState.restore
      runtime.rethrowBudgetAbort
      runtime.restoreBranchBudget branchBudgetBefore
      if expanded then
        runtime.modify fun stats => {
          stats with backtracks := stats.backtracks + 1
        }
      setGoals [goal]
      return false

  /--
  对局部对象等式执行可逆的相继式左规则，并用 Lean 返回的替换映射更新 proof 资源。

  两侧都是局部对象时只消去较新的变量，避免把会话入口参数替换成分支临时量。
  -/
  private unsafe def trySubstitutionCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Bool := do
    let mut inspected := 0
    for equality in resources do
      let orientation? ←
        goal.withContext <| hostObjectSubstitutionOrientation? equality
      let some symm := orientation?
        | continue
      if inspected >= runtime.config.maxTransportCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with transportCandidates := stats.transportCandidates + 1
      }
      let savedState ← saveState
      let mut substituted := false
      try
        let (substitution, child) ←
          substCore goal equality (symm := symm) (tryToSkip := true)
        substituted := true
        let childResources ←
          remapSubstitutedResources
            child resources equality substitution
        trace[YesMetaZFC.proveAuto.sequent]
          "transport.subst depth={depth}; equality={← goal.withContext <|
            renderResourceLabel equality}; symm={symm}; \
          resources={resources.size}->{childResources.size}"
        setGoals [child]
        solveCurrent runtime (depth + 1) <|
          resetRewriteStreak (remapSearchPath path substitution)
        runtime.modify fun stats => {
          stats with transportSteps := stats.transportSteps + 1
        }
        setGoals []
        return true
      catch _ =>
        savedState.restore
        runtime.rethrowBudgetAbort
        if substituted then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

  /--
  分析核已经递归验证过的结构投影等式先物化为局部 proof，再复用同一套对象替换规则。

  这只处理不能由 `localProofResources` 直接看见的投影；直接等式仍由前一个分支负责。
  -/
  private unsafe def tryProjectedSubstitutionCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (view : HostPropAnalysis.View)
      (depth : Nat) (path : HostSequentSearchPath) :
      TacticM Bool := do
    let mut inspected := 0
    for ranked in view.equalities do
      let some resource ← runtime.analysis.resource? ranked.resource
        | continue
      if resource.projectionPath.isEmpty then
        continue
      if inspected >= runtime.config.maxTransportCandidates then
        break
      let savedState ← saveState
      let mut substituted := false
      try
        let name ← mkFreshUserName `projectedEquality
        let (equality, notedGoal) ← goal.note name resource.proof
        let orientation? ← notedGoal.withContext <|
          hostObjectSubstitutionOrientation? equality
        let some symm := orientation?
          | savedState.restore
            continue
        inspected := inspected + 1
        runtime.modify fun stats => {
          stats with transportCandidates := stats.transportCandidates + 1
        }
        let notedResources := resources.push equality
        let (substitution, child) ←
          substCore notedGoal equality (symm := symm) (tryToSkip := true)
        substituted := true
        let childResources ←
          remapSubstitutedResources
            child notedResources equality substitution
        trace[YesMetaZFC.proveAuto.sequent]
          "transport.projected-subst depth={depth}; \
          source={resource.sourceLabel}; projection={resource.projectionPath}; \
          symm={symm}; resources={resources.size}->{childResources.size}"
        setGoals [child]
        solveCurrent runtime (depth + 1) <|
          resetRewriteStreak (remapSearchPath path substitution)
        runtime.modify fun stats => {
          stats with transportSteps := stats.transportSteps + 1
        }
        setGoals []
        return true
      catch _ =>
        savedState.restore
        runtime.rethrowBudgetAbort
        if substituted then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

  private unsafe def tryRewriteCandidates
      (runtime : Runtime) (goal : MVarId)
      (view : HostPropAnalysis.View) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Bool := do
    let rules ← goal.withContext <|
      analysisRewriteRules runtime view path
    let mut inspected := 0
    for rule in rules do
      if inspected >= runtime.config.maxRewriteCandidates then
        break
      inspected := inspected + 1
      for reverse in #[false, true] do
        runtime.modify fun stats => {
          stats with rewriteCandidates := stats.rewriteCandidates + 1
        }
        let savedState ← saveState
        let mut rewritten := false
        try
          let some child ← rewriteTarget? goal rule.proof reverse
            | savedState.restore
              continue
          rewritten := true
          trace[YesMetaZFC.proveAuto.sequent]
            "rewrite.try depth={depth}; resource={rule.label}; \
            source={rule.sourceLabel}; projection={rule.projectionPath}; \
            score={rule.score}; reverse={reverse}"
          setGoals [child]
          solveCurrent runtime (depth + 1) (rememberRewrite path)
          runtime.modify fun stats => {
            stats with rewriteSteps := stats.rewriteSteps + 1
          }
          return true
        catch _ =>
          savedState.restore
          runtime.rethrowBudgetAbort
          if rewritten then
            runtime.modify fun stats => {
              stats with backtracks := stats.backtracks + 1
            }
    setGoals [goal]
    return false

  /-- 用局部量化等式或等价规则改写既有 proof，并把新事实加入当前相继式。 -/
  private unsafe def tryForwardRewriteCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (view : HostPropAnalysis.View)
      (target : Expr) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Bool := do
    let ordered ←
      goal.withContext <|
        orderForwardRewriteResources target resources path.generated
    let resourcePropositions := ordered.map (·.proposition)
    let rules ← goal.withContext <|
      analysisRewriteRules runtime view path
    let mut supports := #[]
    for entry in ordered do
      unless ← goal.withContext <|
          isRewriteProposition entry.proposition do
        supports := supports.push entry
    let mut inspected := 0
    for support in supports do
      if inspected >= runtime.config.maxForwardCandidates then
        break
      for rule in rules do
        if inspected >= runtime.config.maxForwardCandidates then
          break
        for reverse in #[false, true] do
          if inspected >= runtime.config.maxForwardCandidates then
            break
          inspected := inspected + 1
          runtime.modify fun stats => {
            stats with forwardCandidates := stats.forwardCandidates + 1
          }
          let savedState ← saveState
          let direct? ←
            forwardRewriteProof?
              goal rule.proof support.resource reverse
          let (rewritten?, existentialLift) ←
            match direct? with
            | some result =>
                pure (some result, false)
            | none =>
                pure
                  (← forwardExistentialRewriteProof?
                      goal rule.proof support.resource reverse, true)
          let some (proposition, proof) := rewritten?
            | savedState.restore
              continue
          let duplicate :=
            resourcePropositions.any fun existing =>
              Expr.equal existing proposition
          if duplicate || generationOnPath path proposition then
            savedState.restore
            if !duplicate then
              runtime.modify fun stats => {
                stats with generationPrunes := stats.generationPrunes + 1
              }
            continue
          try
            let name ← mkFreshUserName `forwardRewritten
            let (_, child) ← goal.note name proof
            trace[YesMetaZFC.proveAuto.sequent]
              "forward-rewrite.try depth={depth}; rule={rule.label}; \
              ruleSource={rule.sourceLabel}; \
              ruleProjection={rule.projectionPath}; \
              support={support.label}; reverse={reverse}; \
              existentialLift={existentialLift}; \
              supportOverlap={support.targetOverlap}; \
              supportWeight={support.weight}; supportAge={support.age}"
            setGoals [child]
            let nextPath :=
              rememberForwardSimplification
                (rememberRewrite (rememberGeneration path proposition))
                support.proposition
            let nextPath :=
              if existentialLift then
                { nextPath with
                  rewriteStreak := Nat.max nextPath.rewriteStreak 2
                  preferGeneratedRewrite := false }
              else
                { nextPath with preferGeneratedRewrite := false }
            solveCurrent runtime (depth + 1)
              nextPath
            runtime.modify fun stats => {
              stats with forwardSteps := stats.forwardSteps + 1
            }
            setGoals []
            return true
          catch _ =>
            savedState.restore
            runtime.rethrowBudgetAbort
            runtime.modify fun stats => {
              stats with backtracks := stats.backtracks + 1
            }
    setGoals [goal]
    return false

  /-- 目标导向地实例化局部全称 proof，并在新资源上下文中重试当前相继式。 -/
  private unsafe def trySpecializeCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex) :
      TacticM Bool := do
    let mut inspected := 0
    for indexed in index.specialize do
      if inspected >= runtime.config.maxSpecializeCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with
        specializeCandidates := stats.specializeCandidates + 1
      }
      let savedState ← saveState
      let mut expanded := false
      try
        let children ←
          expandHostProofStep #[{ goal := goal, resources := resources }]
            .specialize <|
              specializeHostProofExpr
                indexed.candidate.proof indexed.arguments
        expanded := true
        unless children.size == 1 do
          throwError
            "focused sequent SPECIALIZE expected exactly one child"
        let some child := children[0]?
          | throwError "focused sequent SPECIALIZE lost its child"
        trace[YesMetaZFC.proveAuto.sequent]
          "specialize.try depth={depth}; resource={indexed.candidate.label}; \
          arguments={indexed.arguments.size}"
        setGoals [child.goal]
        solveCurrent runtime (depth + 1) (resetRewriteStreak path)
        runtime.modify fun stats => {
          stats with specializeSteps := stats.specializeSteps + 1
        }
        setGoals []
        return true
      catch _ =>
        savedState.restore
        runtime.rethrowBudgetAbort
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

  /-- 执行严格准入的等式 TRANSPORT，并递归闭合运输后的单个子相继式。 -/
  private unsafe def tryTransportCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex) :
      TacticM Bool := do
    let mut inspected := 0
    for indexed in index.transport do
      if inspected >= runtime.config.maxTransportCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with
        transportCandidates := stats.transportCandidates + 1
      }
      let savedState ← saveState
      let mut expanded := false
      try
        let proof ←
          if indexed.reverseProof then
            goal.withContext <| mkAppM ``Eq.symm #[indexed.equality.proof]
          else
            pure indexed.equality.proof
        let children ←
          expandHostProofStep #[{ goal := goal, resources := resources }]
            .transport <|
              transportHostTargetExpr
                indexed.source indexed.destination proof
        expanded := true
        unless children.size == 1 do
          throwError
            "focused sequent TRANSPORT expected exactly one child"
        let some child := children[0]?
          | throwError "focused sequent TRANSPORT lost its child"
        trace[YesMetaZFC.proveAuto.sequent]
          "transport.try depth={depth}; equality={indexed.equality.label}; \
          support={indexed.support.label}; reverse={indexed.reverseProof}"
        setGoals [child.goal]
        solveCurrent runtime (depth + 1) (resetRewriteStreak path)
        runtime.modify fun stats => {
          stats with transportSteps := stats.transportSteps + 1
        }
        setGoals []
        return true
      catch _ =>
        savedState.restore
        runtime.rethrowBudgetAbort
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

  private unsafe def tryApplyCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (view : HostPropAnalysis.View)
      (target : Expr) (depth : Nat)
      (path : HostSequentSearchPath) (pass : ApplyPass) :
      TacticM Bool := do
    if pass == .probe && runtime.config.maxApplyProbeNodes == 0 then
      return false
    let candidates ← goal.withContext <|
      match pass with
      | .surface =>
          orderRegisteredApplyCandidates runtime view target
      | .probe | .fallback =>
          orderApplyCandidates runtime view target resources
    if pass == .fallback && !candidates.isEmpty then
      runtime.modify fun stats => {
        stats with applyFallbackPasses := stats.applyFallbackPasses + 1
      }
    let mut inspected := 0
    for candidate in candidates do
      if inspected >= runtime.config.maxApplyCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with applyCandidates := stats.applyCandidates + 1
      }
      let ownsProbe ←
        match pass with
        | .probe => runtime.beginApplyProbe
        | .surface | .fallback => pure false
      let branchBudgetBefore ← runtime.branchBudgetCheckpoint
      let savedState ← saveState
      let mut expanded := false
      try
        let directProof? ← goal.withContext do
          let proof ← instantiateMVars candidate.proof
          unless (← getMVarsNoDelayed proof).isEmpty do
            return none
          let proofType ← instantiateMVars (← inferType proof)
          if ← isDefEqGuarded proofType target then
            return some proof
          return none
        if let some proof := directProof? then
          goal.assign proof
          let _ ← runtime.finishApplyProbe ownsProbe
          runtime.modify fun stats => {
            stats with applySteps := stats.applySteps + 1
          }
          trace[YesMetaZFC.proveAuto.sequent]
            "apply.target.closed depth={depth}; pass={pass.label}; \
            resource={candidate.label}"
          setGoals []
          return true
        let plan ← goal.withContext <|
          prepareHostApply candidate.proof target
        expanded := true
        goal.assign plan.application
        let isMainBranch ←
          runtime.claimMainBranchFrontier depth plan.children.size
        trace[YesMetaZFC.proveAuto.sequent]
          "apply.try depth={depth}; pass={pass.label}; resource={candidate.label}; \
          premises={plan.children.size}"
        for index in [0 : plan.children.size] do
          let child := plan.children[index]!
          setGoals [child]
          solveCurrent runtime (depth + 1) (resetRewriteStreak path)
          if index + 1 < plan.children.size then
            runtime.rewardClosedMainBranch isMainBranch
        let _ ← runtime.finishApplyProbe ownsProbe
        runtime.modify fun stats => {
          stats with
          applySteps := stats.applySteps + 1
          generatedPremises :=
            stats.generatedPremises + plan.children.size
        }
        setGoals []
        return true
      catch _ =>
        savedState.restore
        let probeExhausted ← runtime.finishApplyProbe ownsProbe
        unless probeExhausted do
          runtime.rethrowBudgetAbort
        runtime.restoreBranchBudget branchBudgetBefore
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

  /--
  在 overlap CUT 的正分支中按需生成二元合取对象，并把受阻 APPLY 改在该对象上执行。

  生成器只接收 CUT 已确定的两个对象；生成的存在 proof、对象、定义 proof 和 APPLY
  结果都作为普通局部事实加入后续相继式。
  -/
  private unsafe def solveOverlapPositiveBranch
      (runtime : Runtime) (goal : MVarId)
      (cutProof : FVarId) (candidate : OverlapCutCandidate) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Unit := do
    let generators ← registeredHostSequentBinaryConjunctionGenerators
    let resources ← goal.withContext localProofResources
    for generator in generators do
      runtime.modify fun stats => {
        stats with
        overlapGeneratorAttempts := stats.overlapGeneratorAttempts + 1
      }
      let savedState ← saveState
      try
        let some generatedProof ← goal.withContext <|
            instantiateHostSequentBinaryConjunctionGenerator?
              generator candidate.left candidate.right resources
          | savedState.restore
            continue
        let generatedType ← goal.withContext <|
          instantiateMVars (← inferType generatedProof)
        let generatedName ← mkFreshUserName `overlapGenerated
        let (generatedId, generatedGoal) ←
          goal.note generatedName generatedProof (some generatedType)
        setGoals [generatedGoal]
        let objectName ← mkFreshUserName `overlapObject
        let definitionName ← mkFreshUserName `overlapDefinition
        chooseHostProofId generatedId objectName definitionName
        let cutValueName ← mkFreshUserName `overlapValue
        let cutDataName ← mkFreshUserName `overlapValueData
        chooseHostProofId cutProof cutValueName cutDataName
        let generatedGoal ← getMainGoal
        let (object, definitionProof, cutValue, cutData) ←
            withMainContext do
          return (
            mkFVar (← getLocalDeclFromUserName objectName).fvarId,
            mkFVar (← getLocalDeclFromUserName definitionName).fvarId,
            mkFVar (← getLocalDeclFromUserName cutValueName).fvarId,
            mkFVar (← getLocalDeclFromUserName cutDataName).fvarId)
        let nonemptyProof ← withMainContext do
          let definitionAt := mkApp definitionProof cutValue
          let membership ← mkAppM ``Iff.mpr #[definitionAt, cutData]
          let valueType ← inferType cutValue
          let predicate ←
            mkLambdaFVars #[cutValue] (← inferType membership)
          let level := (← inferType valueType).sortLevel!
          return mkAppN (mkConst ``Exists.intro [level])
            #[valueType, predicate, cutValue, membership]
        let specializedApply := mkApp candidate.apply.proof object
        let specializedType ← withMainContext do
          instantiateMVars (← inferType specializedApply)
        let (_, _, auxiliaryTarget) ← withMainContext <|
          forallMetaTelescopeReducing specializedType
        let auxiliaryTarget ← withMainContext <|
          instantiateMVars auxiliaryTarget
        if auxiliaryTarget.hasMVar then
          throwError
            "focused sequent overlap APPLY left an unstable auxiliary target"
        let auxiliaryPlan ← withMainContext <|
          prepareHostApply specializedApply auxiliaryTarget
        let auxiliaryName ← mkFreshUserName `overlapApplied
        let (auxiliaryId, resumedGoal) ←
          generatedGoal.note auxiliaryName auxiliaryPlan.application
            (some auxiliaryTarget)
        for child in auxiliaryPlan.children do
          let childState ← saveState
          let assigned ← child.withContext do
            let childTarget ← instantiateMVars (← child.getType)
            let nonemptyType ← instantiateMVars (← inferType nonemptyProof)
            if ← isDefEq childTarget nonemptyType then
              child.assign nonemptyProof
              return true
            return false
          if !assigned then
            childState.restore
            setGoals [child]
            solveCurrent runtime (depth + 1) (resetRewriteStreak path)
        setGoals [resumedGoal]
        let witnessName ← mkFreshUserName `overlapWitness
        let witnessProofName ← mkFreshUserName `overlapWitnessProof
        chooseHostProofId auxiliaryId witnessName witnessProofName
        let (witness, candidateLeft, candidateRight, least) ←
            withMainContext do
          let witness :=
            mkFVar (← getLocalDeclFromUserName witnessName).fvarId
          let witnessProof :=
            mkFVar (← getLocalDeclFromUserName witnessProofName).fvarId
          let candidateObject ← mkAppM ``And.left #[witnessProof]
          let least ← mkAppM ``And.right #[witnessProof]
          let definitionAt := mkApp definitionProof witness
          let candidateData ← mkAppM ``Iff.mp #[definitionAt, candidateObject]
          let candidateLeft ← mkAppM ``And.left #[candidateData]
          let candidateRight ← mkAppM ``And.right #[candidateData]
          return (witness, candidateLeft, candidateRight, least)
        let candidateLeftName ← mkFreshUserName `overlapCandidateLeft
        let candidateRightName ← mkFreshUserName `overlapCandidateRight
        let leastName ← mkFreshUserName `overlapLeast
        let transferGoal ← getMainGoal
        let (_, transferGoal) ←
          transferGoal.note candidateLeftName candidateLeft
        let (_, transferGoal) ←
          transferGoal.note candidateRightName candidateRight
        let (_, transferGoal) ← transferGoal.note leastName least
        runtime.modify fun stats => {
          stats with witnessCandidates := stats.witnessCandidates + 1
        }
        trace[YesMetaZFC.proveAuto.sequent]
          "overlap.transfer.witness depth={depth}; witness={witnessName}"
        closeOverlapTransfer runtime transferGoal resources definitionProof witness
          candidateLeft candidateRight least (depth + 1)
        runtime.modify fun stats => {
          stats with
          overlapGeneratorSteps := stats.overlapGeneratorSteps + 1
          witnessSteps := stats.witnessSteps + 1
        }
        setGoals []
        return
      catch error =>
        trace[YesMetaZFC.proveAuto.sequent]
          "overlap.generator.failed declaration={generator.declaration}; \
          error={error.toMessageData}"
        savedState.restore
        runtime.rethrowBudgetAbort
        runtime.modify fun stats => {
          stats with backtracks := stats.backtracks + 1
        }
    throwError
      "focused sequent found no binary conjunction generator for the overlap CUT"

  /--
  从受阻 APPLY 产生一个需求驱动的经典 CUT。

  CUT 命题来自前提形状，不枚举任意命题；同一 CUT 已在当前路径出现时直接剪枝。
  -/
  private unsafe def tryOverlapCutCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (view : HostPropAnalysis.View)
      (target : Expr) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Bool := do
    unless target.isAppOfArity ``Exists 2 do
      return false
    let candidates ← goal.withContext <|
      orderApplyCandidates runtime view target resources
    let mut inspected := 0
    for apply in candidates do
      if inspected >= runtime.config.maxApplyCandidates then
        break
      inspected := inspected + 1
      let planState ← saveState
      let candidate? ←
        try
          let plan ← goal.withContext <|
            prepareHostApply apply.proof target
          goal.withContext <|
            overlapCutFromApplyPlan? apply plan resources
        catch _ =>
          pure none
      let candidate? ← candidate?.mapM fun candidate => do
        return {
          candidate with
          cut := ← instantiateMVars candidate.cut
          left := ← instantiateMVars candidate.left
          right := ← instantiateMVars candidate.right
        }
      planState.restore
      let some candidate := candidate?
        | continue
      if generationOnPath path candidate.cut then
        runtime.modify fun stats => {
          stats with generationPrunes := stats.generationPrunes + 1
        }
        continue
      runtime.modify fun stats => {
        stats with overlapCutCandidates := stats.overlapCutCandidates + 1
      }
      let branchBudgetBefore ← runtime.branchBudgetCheckpoint
      let savedState ← saveState
      let mut expanded := false
      try
        let (positive, negative) ← goal.withContext <|
          goal.byCases candidate.cut (← mkFreshUserName `overlap)
        expanded := true
        runtime.addBranchChildren 2
        let isMainBranch ←
          runtime.claimMainBranchFrontier depth 2
        trace[YesMetaZFC.proveAuto.sequent]
          "overlap.cut depth={depth}; resource={candidate.apply.label}; \
          proposition={candidate.cut}"
        let branchPath :=
          resetRewriteStreak (rememberGeneration path candidate.cut)
        setGoals [positive.mvarId]
        solveOverlapPositiveBranch runtime positive.mvarId positive.fvarId candidate
          (depth + 1) branchPath
        runtime.rewardClosedMainBranch isMainBranch
        setGoals [negative.mvarId]
        closeOverlapNegativeTransfer runtime negative.mvarId negative.fvarId
          candidate resources (depth + 1)
        runtime.modify fun stats => {
          stats with overlapCutSteps := stats.overlapCutSteps + 1
        }
        setGoals []
        return true
      catch _ =>
        savedState.restore
        runtime.rethrowBudgetAbort
        runtime.restoreBranchBudget branchBudgetBefore
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

  /--
  在开放通用 rewrite 前只运行轻量的正相位 selector。

  这里直接读取目标安全构造子，不准备完整 branch index，避免高阶上下文为尚未需要的
  CASES/FORWARD 候选支付全量 `isDefEq` 成本。
  -/
  private unsafe def tryGuidedTargetConstructorCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (target : Expr) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Bool := do
    let constructors ← goal.withContext <| targetHostSequentConstructors target
    if constructors.isEmpty then
      return false
    trace[YesMetaZFC.proveAuto.sequent]
      "activation.focused depth={depth}; pass=guidedConstructor"
    tryConstructorCandidates runtime goal resources target depth path
      { constructors := constructors } true

  /--
  完整 branch index 已按原生命周期准备后，执行需要索引的聚焦资源规则。

  多分支 CASES 后先消费能收缩上下文的 demanded FORWARD，再由 CHOOSE 暴露存在
  资源，最后执行左侧 And 的可逆分解。这样复合前提不会在等式规则消费前被拆散。
  -/
  private unsafe def tryFocusedActivationCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex)
      (skipBranchingCases : Bool) :
      TacticM Bool := do
    if !skipBranchingCases && index.cases.any fun candidate =>
        candidate.descriptor.expectedBranches > 1 then
      trace[YesMetaZFC.proveAuto.sequent]
        "activation.focused depth={depth}; pass=branchingCases"
      if ← tryCasesCandidates runtime goal resources depth path index .branching then
        return true
    if index.forward.any fun candidate =>
        ForwardActivationPass.demanded.matches path candidate then
      trace[YesMetaZFC.proveAuto.sequent]
        "activation.focused depth={depth}; pass=demandedForward"
      if ← tryForwardCandidates runtime goal resources depth path index .demanded then
        return true
    if let some preferred := path.preferredCases.back? then
      if index.cases.any fun candidate =>
          candidate.descriptor.expectedBranches == 1 &&
            Expr.equal candidate.candidate.proof preferred then
        trace[YesMetaZFC.proveAuto.sequent]
          "activation.focused depth={depth}; pass=preferredUnaryCases"
        if ←
            tryCasesCandidates runtime goal resources depth path index
              .preferredUnary then
          return true
    if index.cases.any fun candidate =>
        candidate.unlockScore > 0 &&
          candidate.descriptor.expectedBranches == 1 &&
          candidate.descriptor.inductiveName == ``And then
      trace[YesMetaZFC.proveAuto.sequent]
        "activation.focused depth={depth}; pass=demandedLogicalUnaryCases"
      if ←
          tryCasesCandidates runtime goal resources depth path index
            .demandedLogicalUnary then
        return true
    if !index.choose.isEmpty then
      trace[YesMetaZFC.proveAuto.sequent]
        "activation.focused depth={depth}; pass=choose"
      if ←
          tryChooseCandidates
            runtime goal resources depth path index .any then
        return true
    if index.cases.any fun candidate =>
        candidate.descriptor.expectedBranches == 1 &&
          candidate.descriptor.inductiveName == ``And &&
          !candidate.preserveForForward then
      trace[YesMetaZFC.proveAuto.sequent]
        "activation.focused depth={depth}; pass=logicalUnaryCases"
      if ←
          tryCasesCandidates runtime goal resources depth path index .logicalUnary then
        return true
    setGoals [goal]
    return false

  /-- 聚焦相位和通用 rewrite 均未闭合后，执行非投影型 residual activation。 -/
  private unsafe def tryResidualActivationCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (target : Expr) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex) :
      TacticM Bool := do
    if !index.constructors.isEmpty then
      trace[YesMetaZFC.proveAuto.sequent]
        "activation.residual depth={depth}; pass=constructor"
      if ← tryConstructorCandidates
          runtime goal resources target depth path index false then
        return true
    if index.forward.any fun candidate =>
        ForwardActivationPass.residual.matches path candidate then
      trace[YesMetaZFC.proveAuto.sequent]
        "activation.residual depth={depth}; pass=forward"
      if ← tryForwardCandidates runtime goal resources depth path index .residual then
        return true
    setGoals [goal]
    return false

  /--
  单构造子 CASES 只作为完整 APPLY 之后的最后后备。

  结构投影已由 HostPropAnalysis 缓存；过早拆结构只会复制同一组投影并扩大上下文。
  -/
  private unsafe def tryUnaryCasesCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex) :
      TacticM Bool := do
    if index.cases.any fun candidate =>
        candidate.descriptor.expectedBranches == 1 &&
          (candidate.descriptor.inductiveName != ``And ||
            candidate.preserveForForward) then
      trace[YesMetaZFC.proveAuto.sequent]
        "activation.fallback depth={depth}; pass=unaryCases"
      if ←
          tryCasesCandidates runtime goal resources depth path index .structuralUnary then
        return true
    setGoals [goal]
    return false

  /-- 用已确定的对象与 proof 参数生成 FORWARD 新事实，并重试当前相继式。 -/
  private unsafe def tryForwardCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex)
      (pass : ForwardActivationPass) :
      TacticM Bool := do
    let mut inspected := 0
    for indexed in index.forward do
      unless pass.matches path indexed do
        continue
      let proposition ←
        goal.withContext <| instantiateMVars indexed.descriptor.result
      if generationOnPath path proposition then
        runtime.modify fun stats => {
          stats with generationPrunes := stats.generationPrunes + 1
        }
        continue
      if inspected >= runtime.config.maxForwardCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with forwardCandidates := stats.forwardCandidates + 1
      }
      let savedState ← saveState
      let mut expanded := false
      try
        let children ←
          expandHostProofStep #[{ goal := goal, resources := resources }]
            .forward <|
              forwardHostSequentExpr indexed.descriptor
                indexed.candidate indexed.arguments
        expanded := true
        unless children.size == 1 do
          throwError "focused sequent FORWARD expected exactly one child"
        let some child := children[0]?
          | throwError "focused sequent FORWARD lost its child"
        trace[YesMetaZFC.proveAuto.sequent]
          "forward.try depth={depth}; resource={indexed.candidate.label}; \
          arguments={indexed.arguments.size}; result={proposition}"
        let closesTarget ← child.goal.withContext do
          let target ← instantiateMVars (← child.goal.getType)
          let savedState ← saveState
          let closes ←
            try
              isDefEq proposition target
            catch _ =>
              pure false
          savedState.restore
          pure closes
        if closesTarget then
          let proof ← child.goal.withContext do
            let proof ← instantiateMVars <|
              mkAppN indexed.candidate.proof indexed.arguments
            unless (← getMVarsNoDelayed proof).isEmpty do
              throwError
                "focused sequent FORWARD closing proof contains unresolved metavariables"
            let proofType ← whnf (← instantiateMVars (← inferType proof))
            let target ← instantiateMVars (← child.goal.getType)
            unless ← isDefEq proofType target do
              throwError
                "focused sequent FORWARD closing proof no longer matches the target"
            pure proof
          child.goal.assign proof
          runtime.modify fun stats => {
            stats with
              forwardSteps := stats.forwardSteps + 1
              initialRuleClosures := stats.initialRuleClosures + 1
          }
          trace[YesMetaZFC.proveAuto.sequent]
            "forward.target.closed depth={depth}; resource={indexed.candidate.label}"
          setGoals []
          return true
        if proposition.isConstOf ``False then
          let falseProof ← child.goal.withContext do
            let proof ← instantiateMVars <|
              mkAppN indexed.candidate.proof indexed.arguments
            unless (← getMVarsNoDelayed proof).isEmpty do
              throwError
                "focused sequent FORWARD False proof contains unresolved metavariables"
            let proofType ← whnf (← instantiateMVars (← inferType proof))
            unless proofType.isConstOf ``False do
              throwError
                "focused sequent FORWARD False proof no longer has type False"
            pure proof
          let closedProof ← child.goal.withContext do
            let target ← instantiateMVars (← child.goal.getType)
            let resultLevel := (← inferType target).sortLevel!
            pure <|
              mkApp2 (mkConst ``False.elim [resultLevel]) target falseProof
          child.goal.assign closedProof
          runtime.modify fun stats => {
            stats with
            forwardSteps := stats.forwardSteps + 1
            initialRuleClosures := stats.initialRuleClosures + 1
          }
          trace[YesMetaZFC.proveAuto.sequent]
            "forward.false.closed depth={depth}; resource={indexed.candidate.label}"
          setGoals []
          return true
        if let some equality :=
            child.resources.find? fun resource => !resources.contains resource then
          let orientation? ← child.goal.withContext <|
            hostObjectSubstitutionOrientation? equality
          if let some symm := orientation? then
            runtime.modify fun stats => {
              stats with transportCandidates := stats.transportCandidates + 1
            }
            let equalityLabel ← child.goal.withContext <|
              renderResourceLabel equality
            let (substitution, substitutedGoal) ←
              substCore child.goal equality (symm := symm) (tryToSkip := true)
            let substitutedResources ←
              remapSubstitutedResources
                substitutedGoal child.resources equality substitution
            trace[YesMetaZFC.proveAuto.sequent]
              "forward.subst depth={depth}; resource={indexed.candidate.label}; \
              equality={equalityLabel}; symm={symm}; \
              resources={child.resources.size}->{substitutedResources.size}"
            let remappedPath := remapSearchPath path substitution
            let remappedProposition := substitution.apply proposition
            setGoals [substitutedGoal]
            solveCurrent runtime (depth + 1)
              (resetRewriteStreak <|
                rememberGeneration remappedPath remappedProposition)
            runtime.modify fun stats => {
              stats with
                forwardSteps := stats.forwardSteps + 1
                transportSteps := stats.transportSteps + 1
            }
            setGoals []
            return true
        setGoals [child.goal]
        solveCurrent runtime (depth + 1)
          (resetRewriteStreak (rememberGeneration path proposition))
        runtime.modify fun stats => {
          stats with forwardSteps := stats.forwardSteps + 1
        }
        setGoals []
        return true
      catch error =>
        savedState.restore
        runtime.rethrowBudgetAbort
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
        trace[YesMetaZFC.proveAuto.sequent]
          "forward.backtrack depth={depth}; resource={indexed.candidate.label}; \
          result={proposition}; reason={error.toMessageData}"
    setGoals [goal]
    return false

  /-- CHOOSE 暴露的对象优先服务随后出现的 Exists 目标；失败后完整回退。 -/
  private unsafe def tryPreferredWitnessCandidate
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Bool := do
    if path.preferredWitnesses.isEmpty then
      return false
    let target ← goal.withContext do
      whnf (← instantiateMVars (← goal.getType))
    unless target.isAppOfArity ``Exists 2 do
      return false
    let witness := path.preferredWitnesses.back!
    let remaining := path.preferredWitnesses.pop
    let savedState ← saveState
    let mut expanded := false
    try
      let children ←
        expandHostProofStep #[{ goal := goal, resources := resources }]
          .witness <| witnessHostTargetExpr witness
      expanded := true
      unless children.size == 1 do
        throwError
          "focused sequent preferred WITNESS expected exactly one child"
      let some child := children[0]?
        | throwError "focused sequent preferred WITNESS lost its child"
      trace[YesMetaZFC.proveAuto.sequent]
        "witness.preferred depth={depth}; witness={witness}"
      setGoals [child.goal]
      solveCurrent runtime (depth + 1) <|
        resetRewriteStreak {
          path with preferredWitnesses := remaining
        }
      runtime.modify fun stats => {
        stats with witnessSteps := stats.witnessSteps + 1
      }
      setGoals []
      return true
    catch _ =>
      savedState.restore
      runtime.rethrowBudgetAbort
      if expanded then
        runtime.modify fun stats => {
          stats with backtracks := stats.backtracks + 1
        }
    setGoals [goal]
    return false

  /--
  只提前消费会立即暴露当前目标投影的 Exists 资源。

  普通 CHOOSE 仍保留在 residual activation 之后；这里不会因为上下文中存在任意
  existential 就抢在目标构造器前展开。
  -/
  private unsafe def tryProjectedChooseCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (target : Expr) (depth : Nat)
      (path : HostSequentSearchPath) :
      TacticM Bool := do
    let scanCount := min resources.size runtime.config.maxChooseCandidates
    for offset in [0 : scanCount] do
      let resourceId := resources[resources.size - offset - 1]!
      let proposition ← goal.withContext do
        instantiateMVars (← whnf (← resourceId.getType))
      unless proposition.isAppOfArity ``Exists 2 do
        continue
      runtime.modify fun stats => {
        stats with chooseCandidates := stats.chooseCandidates + 1
      }
      let savedState ← saveState
      let mut expanded := false
      try
        let witnessName ← mkFreshUserName `chosen
        let proofName ← mkFreshUserName `chosenProof
        let children ←
          expandHostProofStep #[{ goal := goal, resources := resources }]
            .choose <|
              chooseHostProofId resourceId
                witnessName proofName
        expanded := true
        unless children.size == 1 do
          throwError
            "focused sequent projected CHOOSE expected exactly one child"
        let some child := children[0]?
          | throwError "focused sequent projected CHOOSE lost its child"
        let instanceProof ← child.goal.withContext do
          return mkFVar
            (← getLocalDeclFromUserName proofName).fvarId
        unless ← child.goal.withContext <|
            proofProjectsTarget instanceProof target do
          savedState.restore
          continue
        trace[YesMetaZFC.proveAuto.sequent]
          "choose.projected depth={depth}; \
          resource={← goal.withContext <| renderResourceLabel resourceId}; \
          witness={witnessName}; proof={proofName}"
        setGoals [child.goal]
        solveCurrent runtime (depth + 1) (resetRewriteStreak path)
        runtime.modify fun stats => {
          stats with chooseSteps := stats.chooseSteps + 1
        }
        setGoals []
        return true
      catch error =>
        savedState.restore
        runtime.rethrowBudgetAbort
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
        trace[YesMetaZFC.proveAuto.sequent]
          "choose.projected.backtrack depth={depth}; reason={error.toMessageData}"
    setGoals [goal]
    return false

  /-- 消去局部 Exists proof，并把见证与实例 proof 加入 child 上下文。 -/
  private unsafe def tryChooseCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex)
      (pass : ChooseActivationPass) :
      TacticM Bool := do
    let mut inspected := 0
    let candidates :=
      if pass == .generated then index.choose.reverse else index.choose
    for indexed in candidates do
      if pass == .generated &&
          !generationOnPath path indexed.candidate.proposition then
        continue
      if inspected >= runtime.config.maxChooseCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with chooseCandidates := stats.chooseCandidates + 1
      }
      let savedState ← saveState
      let mut expanded := false
      try
        let witnessName ← mkFreshUserName `chosen
        let proofName ← mkFreshUserName `chosenProof
        let children ←
          expandHostProofStep #[{ goal := goal, resources := resources }]
            .choose <|
              chooseHostProofId indexed.candidate.proof.fvarId!
                witnessName proofName
        expanded := true
        unless children.size == 1 do
          throwError "focused sequent CHOOSE expected exactly one child"
        let some child := children[0]?
          | throwError "focused sequent CHOOSE lost its child"
        trace[YesMetaZFC.proveAuto.sequent]
          "choose.try depth={depth}; resource={indexed.candidate.label}; \
          witness={witnessName}; proof={proofName}"
        let witness ← child.goal.withContext do
          return mkFVar
            (← getLocalDeclFromUserName witnessName).fvarId
        let instanceProof ← child.goal.withContext do
          return mkFVar
            (← getLocalDeclFromUserName proofName).fvarId
        let instanceProposition ← child.goal.withContext do
          instantiateMVars (← inferType instanceProof)
        let preferCases ← child.goal.withContext do
          let proposition ← whnf instanceProposition
          pure (proposition.isAppOfArity ``And 2)
        let sourceGenerated :=
          generationOnPath path indexed.candidate.proposition
        let nextPath := {
          path with
          preferredWitnesses := path.preferredWitnesses.push witness
          preferredCases :=
            if preferCases then
              path.preferredCases.push instanceProof
            else
              path.preferredCases
        }
        let nextPath :=
          if sourceGenerated then
            { rememberGeneration nextPath instanceProposition with
              preferGeneratedRewrite := true }
          else
            nextPath
        setGoals [child.goal]
        solveCurrent runtime (depth + 1) (resetRewriteStreak nextPath)
        runtime.modify fun stats => {
          stats with chooseSteps := stats.chooseSteps + 1
        }
        setGoals []
        return true
      catch _ =>
        savedState.restore
        runtime.rethrowBudgetAbort
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

  /-- 对目标的安全构造子执行 checked APPLY，并递归闭合全部显式命题字段。 -/
  private unsafe def tryConstructorCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (target : Expr) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex) (guidedOnly : Bool) :
      TacticM Bool := do
    let candidates ←
      orderConstructorCandidates runtime goal target resources index.constructors
    let mut inspected := 0
    for scored in candidates do
      let descriptor := scored.descriptor
      if guidedOnly && scored.distance?.isNone then
        continue
      if inspected >= runtime.config.maxConstructorCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with
        constructorCandidates := stats.constructorCandidates + 1
      }
      let branchBudgetBefore ← runtime.branchBudgetCheckpoint
      let savedState ← saveState
      let mut expanded := false
      try
        let proof ← goal.withContext <|
          mkConstWithFreshMVarLevels descriptor.constructorName
        let plan ← goal.withContext <| prepareHostApply proof target
        expanded := true
        goal.assign plan.application
        runtime.addBranchChildren plan.children.size
        let isMainBranch ←
          runtime.claimMainBranchFrontier depth plan.children.size
        trace[YesMetaZFC.proveAuto.sequent]
          "constructor.try depth={depth}; \
          constructor={descriptor.constructorName}; \
          selectorDistance={scored.distance?}; children={plan.children.size}"
        for index in [0 : plan.children.size] do
          let child := plan.children[index]!
          setGoals [child]
          solveCurrent runtime (depth + 1) (resetRewriteStreak path)
          if index + 1 < plan.children.size then
            runtime.rewardClosedMainBranch isMainBranch
        runtime.modify fun stats => {
          stats with
          constructorSteps := stats.constructorSteps + 1
          generatedPremises :=
            stats.generatedPremises + plan.children.size
        }
        trace[YesMetaZFC.proveAuto.sequent]
          "constructor.closed depth={depth}; \
          constructor={descriptor.constructorName}; children={plan.children.size}"
        setGoals []
        return true
      catch error =>
        savedState.restore
        runtime.rethrowBudgetAbort
        runtime.restoreBranchBudget branchBudgetBefore
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
          trace[YesMetaZFC.proveAuto.sequent]
            "constructor.backtrack depth={depth}; \
            constructor={descriptor.constructorName}; \
            reason={error.toMessageData}"
    setGoals [goal]
    return false

  /-- 对安全有限归纳命题执行 CASES；任一分支失败时恢复整个候选。 -/
  private unsafe def tryCasesCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex)
      (pass : CasesActivationPass) :
      TacticM Bool := do
    let mut inspected := 0
    -- 一元 And 分解是可逆步骤，优先消费最新产生的局部资源，避免先展开旧结构的
    -- 深层函数编码；真实多分支 CASES 仍保持原来的稳定候选顺序。
    let candidates :=
      if pass == .logicalUnary || pass == .demandedLogicalUnary ||
          pass == .preferredUnary then
        index.cases.reverse
      else
        index.cases
    for indexed in candidates do
      unless pass.matches indexed.descriptor do
        continue
      if pass == .preferredUnary then
        let some preferred := path.preferredCases.back?
          | continue
        unless Expr.equal indexed.candidate.proof preferred do
          continue
      if pass == .demandedLogicalUnary && indexed.unlockScore == 0 then
        continue
      if pass == .logicalUnary && indexed.preserveForForward then
        continue
      if pass == .structuralUnary &&
          indexed.descriptor.inductiveName == ``And &&
          !indexed.preserveForForward then
        continue
      if inspected >= runtime.config.maxCasesCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with casesCandidates := stats.casesCandidates + 1
      }
      let branchBudgetBefore ← runtime.branchBudgetCheckpoint
      let savedState ← saveState
      let mut expanded := false
      try
        let children ←
          expandHostProofStep #[{ goal := goal, resources := resources }]
            .cases <|
              casesHostProofExprExpected
                indexed.descriptor indexed.candidate.proof
        expanded := true
        runtime.addBranchChildren children.size
        let isMainBranch ←
          runtime.claimMainBranchFrontier depth children.size
        trace[YesMetaZFC.proveAuto.sequent]
          "cases.try depth={depth}; resource={indexed.candidate.label}; \
           inductive={indexed.descriptor.inductiveName}; \
           branches={children.size}; unlock={indexed.unlockScore}"
        let childPath :=
          if pass == .preferredUnary then
            { path with preferredCases := path.preferredCases.pop }
          else
            path
        let sourceGenerated :=
          generationOnPath path indexed.candidate.proposition
        for index in [0 : children.size] do
          let some child := children[index]?
            | throwError "focused sequent CASES lost branch {index + 1}"
          let branchPath ←
            if sourceGenerated then
              child.goal.withContext do
                let mut branchPath := childPath
                let mut exposedGenerated := false
                for resource in child.resources do
                  unless resources.contains resource do
                    let proposition ←
                      instantiateMVars (← resource.getType)
                    unless generationOnPath branchPath proposition do
                      branchPath := rememberGeneration branchPath proposition
                      exposedGenerated := true
                pure <|
                  if exposedGenerated then
                    { branchPath with preferGeneratedRewrite := true }
                  else
                    branchPath
            else
              pure childPath
          setGoals [child.goal]
          solveCurrent runtime (depth + 1) (resetRewriteStreak branchPath)
          if index + 1 < children.size then
            runtime.rewardClosedMainBranch isMainBranch
        runtime.modify fun stats => {
          stats with casesSteps := stats.casesSteps + 1
        }
        setGoals []
        return true
      catch _ =>
        savedState.restore
        runtime.rethrowBudgetAbort
        runtime.restoreBranchBudget branchBudgetBefore
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

  /-- 对 Exists 目标选取有限 typed witness，并递归闭合实例子相继式。 -/
  private unsafe def tryWitnessCandidates
      (runtime : Runtime) (goal : MVarId)
      (resources : Array FVarId) (depth : Nat)
      (path : HostSequentSearchPath)
      (index : HostSequentBranchIndex) :
      TacticM Bool := do
    let mut inspected := 0
    for indexed in index.witness do
      if inspected >= runtime.config.maxWitnessCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with witnessCandidates := stats.witnessCandidates + 1
      }
      let savedState ← saveState
      let mut expanded := false
      try
        let children ←
          expandHostProofStep #[{ goal := goal, resources := resources }]
            .witness <|
              witnessHostTargetExpr indexed.descriptor.witness
        expanded := true
        unless children.size == 1 do
          throwError "focused sequent WITNESS expected exactly one child"
        let some child := children[0]?
          | throwError "focused sequent WITNESS lost its child"
        trace[YesMetaZFC.proveAuto.sequent]
          "witness.try depth={depth}; source={indexed.descriptor.label}; \
          position={indexed.descriptor.position}"
        setGoals [child.goal]
        solveCurrent runtime (depth + 1) (resetRewriteStreak path)
        runtime.modify fun stats => {
          stats with witnessSteps := stats.witnessSteps + 1
        }
        setGoals []
        return true
      catch _ =>
        savedState.restore
        runtime.rethrowBudgetAbort
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

  /-- 执行已经完整预检、且叶子均由固定资源精确闭合的有限反证链。 -/
  private unsafe def tryContradictionCandidates
      (runtime : Runtime) (goal : MVarId) (depth : Nat)
      (index : HostSequentBranchIndex) :
      TacticM Bool := do
    let mut inspected := 0
    for indexed in index.contradictions do
      if inspected >= runtime.config.maxContradictionCandidates then
        break
      inspected := inspected + 1
      runtime.modify fun stats => {
        stats with
        contradictionCandidates := stats.contradictionCandidates + 1
      }
      let savedState ← saveState
      let mut expanded := false
      try
        setGoals [goal]
        applyHostContradiction indexed.producer indexed.descriptor
        expanded := true
        let children := (← getGoals).toArray
        unless children.size == indexed.descriptor.expectedChildren do
          throwError
            "focused sequent contradiction child count changed after admission"
        for child in children do
          setGoals [child]
          let some _ ← HostSequent.tryInitialRule {
                goal := child
                resources := indexed.descriptor.initialResources
              }
            | throwError
                "focused sequent contradiction child lost its initial-rule resource"
        runtime.addBranchChildren children.size
        runtime.modify fun stats => {
          stats with contradictionSteps := stats.contradictionSteps + 1
        }
        trace[YesMetaZFC.proveAuto.sequent]
          "contradiction.closed depth={depth}; \
          producer={indexed.producer.label}; \
          witness={indexed.descriptor.witnessLabel}; children={children.size}"
        setGoals []
        return true
      catch _ =>
        savedState.restore
        runtime.rethrowBudgetAbort
        if expanded then
          runtime.modify fun stats => {
            stats with backtracks := stats.backtracks + 1
          }
    setGoals [goal]
    return false

end

/-- 运行聚焦相继式前端；整体失败时恢复调用前 Meta 状态。 -/
unsafe def run (config : Config := {}) : TacticM Stats := do
  let savedState ← saveState
  let stats ← IO.mkRef ({} : Stats)
  let chargedNodes ← IO.mkRef 0
  let nodeCredits ← IO.mkRef 0
  let mainBranchDepth ← IO.mkRef (none : Option Nat)
  let chargedBranchChildren ← IO.mkRef 0
  let applyProbe ← IO.mkRef (none : Option ApplyProbe)
  let budgetAbort ← IO.mkRef (none : Option HostSequentBudgetAbort)
  try
    let prepared ← HostNormalization.CheckedTransaction.prepare
    let analysis ← HostPropAnalysis.Session.create
    let runtime : Runtime := {
      config
      prepared
      analysis
      stats
      chargedNodes
      nodeCredits
      mainBranchDepth
      chargedBranchChildren
      applyProbe
      budgetAbort
    }
    runtime.recordNormalizationPrepare prepared.stats
    trace[YesMetaZFC.proveAuto.normalization]
      "prepare.done compileNs={prepared.stats.compileElapsedNs}; \
      prepareNs={prepared.stats.prepareElapsedNs}; \
      validateNs={prepared.stats.validationElapsedNs}; \
      rules={prepared.stats.rules}; \
      indexed={prepared.stats.indexedRules}; \
      fallback={prepared.stats.fallbackRules}"
    solveCurrent runtime 0 {}
    let result ← stats.get
    trace[YesMetaZFC.proveAuto.sequent]
      "closed nodes={result.nodes}; chargedNodes={result.chargedNodes}; \
      mainBranchDepth={result.mainBranchDepth}; \
      mainBranchCredits={result.activeNodeCredits}/{result.nodeCreditsGranted}; \
      mainBranchCreditEvents={result.mainBranchCreditEvents}; \
      nodeLimit={runtime.config.maxNodes + result.activeNodeCredits}/\
      {runtime.config.maxNodes + runtime.config.maxEarnedNodeCredits}; \
      applyProbeNodes={result.applyProbeNodes}; \
      applyProbeAborts={result.applyProbeAborts}; \
      applyFallbackPasses={result.applyFallbackPasses}; \
      overlapCuts={result.overlapCutSteps}/{result.overlapCutCandidates}; \
      overlapGenerators={result.overlapGeneratorSteps}/\
      {result.overlapGeneratorAttempts}; \
      overlapTransfers={result.overlapPositiveTransfers}/\
      {result.overlapNegativeTransfers}; \
      initial={result.initialRuleClosures}; \
      intro={result.introSteps}; split={result.splitSteps}; \
      rewrites={result.rewriteSteps}; specialize={result.specializeSteps}; \
      transport={result.transportSteps}; apply={result.applySteps}; \
      forward={result.forwardSteps}; choose={result.chooseSteps}; \
      witness={result.witnessSteps}; premises={result.generatedPremises}; \
      cases={result.casesSteps}; constructors={result.constructorSteps}; \
      constructorSelector={result.constructorSelectorGuided}/\
      {result.constructorSelectorProbes}; \
      contradictions={result.contradictionSteps}; \
      branchChildren={result.branchChildren}; \
      chargedBranchChildren={result.chargedBranchChildren}; \
      branchIndexes={result.branchIndexPreparations}; \
      branchIndexFailures={result.branchIndexFailures}; \
      terminals={result.terminalClosures}/{result.terminalCalls}; \
      providerCalls={result.providerCalls}; providerBuilds={result.providerBuilds}; \
      backtracks={result.backtracks}; cycles={result.cyclePrunes}; \
      generationPrunes={result.generationPrunes}; \
      rewriteDeferrals={result.rewriteDeferrals}; \
      maxRewriteStreak={result.maxRewriteStreak}; \
      budgetAborts={result.budgetAborts}; \
      normalizationCalls={result.normalizationCalls}; \
      normalizationClosures={result.normalizationCheckedClosures}; \
      normalizationValidated={result.normalizationResultValidatedClosures}; \
      normalizationNoOp={result.normalizationNoOpClosures}; \
      normalizationReplayPruned={result.normalizationNoOpReplayPrunes}; \
      normalizationReplayed={result.normalizationReplayedClosures}; \
      normalizationNodes={result.normalizationNodes}; \
      normalizationAttempts={result.normalizationAttempts}; \
      normalizationConservative={result.normalizationConservativeEdges}/\
      {result.normalizationConservativeAttempts}; \
      normalizationPhaseQueries={result.normalizationPhaseQueries}; \
      normalizationEmptyPhasePrunes={result.normalizationEmptyPhasePrunes}; \
      normalizationBacktracks={result.normalizationBacktracks}; \
      normalizationCycles={result.normalizationCycles}; \
      normalizationPaths={result.normalizationPaths}; \
      normalizationCandidates={result.normalizationCandidateRules}; \
      normalizationIndexQueries={result.normalizationIndexQueries}; \
      normalizationIndexed={result.normalizationIndexedCandidates}; \
      normalizationRewrites={result.normalizationRewrites}; \
